---
interface PricingTier {
    label: string;        // e.g., "Small Job"
    sqftRange: string;    // e.g., "Up to 75 SF"
    minSqft: number;
    maxSqft: number;      // use Infinity for top tier
    price: number;        // primary price/sqft
    altPrice?: number;    // alternate price (e.g., Blackout variant)
}

interface Variant {
    name: string;         // e.g., "Light Filtering"
    useAltPrice?: boolean;// if true, use tier.altPrice
}

interface MotorOption {
    name: string;
    pricePerShade: number;
    hubPrice?: number;
    description?: string;
}

interface Props {
    productName: string;
    pricingType: "tier" | "contact";
    tiers?: PricingTier[];
    variants?: Variant[];
    motorOptions?: MotorOption[];
    note: string;
}

const { productName, pricingType, tiers = [], variants = [], motorOptions = [], note } = Astro.props;
const estimatorId = `estimator-${productName.toLowerCase().replace(/\s+/g, '-')}`;
---

<section id="estimator-section" data-estimator-id={estimatorId}>
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">Cost Estimator</span>
            <h2 class="cs-title">Estimate Your Investment</h2>
            <p class="cs-text">
                Enter your window measurements below for a rough estimate.
                {pricingType === "contact"
                    ? " Submit your details and we'll provide a custom quote."
                    : " Larger jobs receive better per-square-foot pricing — your exact total is confirmed during your free in-home consultation."
                }
            </p>
        </div>

        <div class="cs-estimator-body">
            {/* Variant Selector — e.g., Light Filtering vs Blackout */}
            {variants.length > 1 && (
                <div class="cs-option-selector">
                    <label class="cs-option-label">Choose Style</label>
                    <div class="cs-option-group">
                        {variants.map((variant, i) => (
                            <label class="cs-radio-label">
                                <input
                                    type="radio"
                                    name={`${estimatorId}-variant`}
                                    value={i.toString()}
                                    checked={i === 0}
                                    class="cs-radio cs-variant-radio"
                                    data-use-alt={variant.useAltPrice ? "1" : "0"}
                                    data-name={variant.name}
                                />
                                <span class="cs-radio-text">{variant.name}</span>
                            </label>
                        ))}
                    </div>
                </div>
            )}

            {/* Window Entries */}
            <div class="cs-windows-container">
                <div class="cs-window-row" data-window-index="0">
                    <div class="cs-window-header">
                        <span class="cs-window-label">Window 1</span>
                    </div>
                    <div class="cs-window-inputs">
                        <div class="cs-input-group">
                            <label class="cs-input-label">Width (inches)</label>
                            <input type="number" class="cs-input cs-width" min="1" max="200" placeholder="36" />
                        </div>
                        <span class="cs-multiply">×</span>
                        <div class="cs-input-group">
                            <label class="cs-input-label">Height (inches)</label>
                            <input type="number" class="cs-input cs-height" min="1" max="200" placeholder="48" />
                        </div>
                    </div>
                </div>
            </div>

            <button class="cs-add-window" type="button">
                <span>+</span> Add Another Window
            </button>

            {/* Motor Add-On Selector */}
            {motorOptions.length > 0 && (
                <div class="cs-motor-section">
                    <label class="cs-option-label">Motorization (Optional)</label>
                    <div class="cs-option-group">
                        <label class="cs-radio-label">
                            <input
                                type="radio"
                                name={`${estimatorId}-motor`}
                                value="-1"
                                checked
                                class="cs-radio cs-motor-radio"
                                data-shade-price="0"
                                data-hub-price="0"
                                data-motor-name="None"
                            />
                            <span class="cs-radio-text">No Motor (Manual)</span>
                        </label>
                        {motorOptions.map((motor, i) => (
                            <label class="cs-radio-label">
                                <input
                                    type="radio"
                                    name={`${estimatorId}-motor`}
                                    value={i.toString()}
                                    class="cs-radio cs-motor-radio"
                                    data-shade-price={motor.pricePerShade.toString()}
                                    data-hub-price={(motor.hubPrice || 0).toString()}
                                    data-motor-name={motor.name}
                                />
                                <span class="cs-radio-text">
                                    {motor.name}
                                    {motor.description && <small class="cs-radio-desc">{motor.description}</small>}
                                </span>
                            </label>
                        ))}
                    </div>
                </div>
            )}

            {/* Results */}
            {pricingType === "tier" ? (
                <div class="cs-results">
                    <div class="cs-tier-display" id={`${estimatorId}-tier`}>
                        <span class="cs-tier-label">Enter window dimensions to see your tier</span>
                    </div>
                    <div class="cs-total-row">
                        <span class="cs-total-label">Estimated Total</span>
                        <span class="cs-total-value">$0</span>
                    </div>
                    <p class="cs-monthly-estimate">
                        or as low as <span class="cs-monthly-value">$0</span>/mo with financing
                    </p>
                    <div class="cs-financing-badges">
                        <img src="/assets/images/partners/wisetack-logo.svg" alt="Wisetack" height="20" loading="lazy" />
                        <span class="cs-financing-divider">|</span>
                        <img src="/assets/images/partners/klarna-logo.svg" alt="Klarna" height="20" loading="lazy" />
                    </div>
                    <p class="cs-disclaimer">{note}</p>
                    <a href="/book" class="cs-button-solid">Book Free Consultation</a>
                </div>
            ) : (
                <div class="cs-results">
                    <div class="cs-contact-message">
                        <p>Every {productName.toLowerCase()} project is unique. Submit your window details and we'll provide a personalized quote tailored to your job.</p>
                    </div>
                    <div class="cs-financing-badges">
                        <img src="/assets/images/partners/wisetack-logo.svg" alt="Wisetack" height="20" loading="lazy" />
                        <span class="cs-financing-divider">|</span>
                        <img src="/assets/images/partners/klarna-logo.svg" alt="Klarna" height="20" loading="lazy" />
                    </div>
                    <p class="cs-disclaimer">{note}</p>
                    <a href="/book" class="cs-button-solid">Request Custom Quote</a>
                </div>
            )}
        </div>
    </div>
</section>

<script is:inline define:vars={{ estimatorId, pricingType, tiers, variants }}>
(function() {
    const section = document.querySelector(`[data-estimator-id="${estimatorId}"]`);
    if (!section || pricingType === 'contact') {
        // Still wire up add-window for contact mode
        if (section) wireAddWindow();
        return;
    }

    const container = section.querySelector('.cs-windows-container');
    const addBtn = section.querySelector('.cs-add-window');
    const totalEl = section.querySelector('.cs-total-value');
    const monthlyEl = section.querySelector('.cs-monthly-value');
    const tierEl = section.querySelector(`#${estimatorId}-tier`);
    let windowCount = 1;

    function getCurrentTier(totalSqft) {
        if (totalSqft <= 0) return null;
        for (let i = 0; i < tiers.length; i++) {
            const t = tiers[i];
            const max = t.maxSqft === null || t.maxSqft >= 99999 ? Infinity : t.maxSqft;
            if (totalSqft >= t.minSqft && totalSqft <= max) return t;
        }
        return tiers[tiers.length - 1] || null;
    }

    function isUsingAltPrice() {
        if (variants.length <= 1) return false;
        const checked = section.querySelector(`input[name="${estimatorId}-variant"]:checked`);
        return checked ? checked.dataset.useAlt === '1' : false;
    }

    function getMotorTotal(shadeCount) {
        const motorRadio = section.querySelector(`input[name="${estimatorId}-motor"]:checked`);
        if (!motorRadio) return 0;
        const shadePrice = parseFloat(motorRadio.dataset.shadePrice) || 0;
        const hubPrice = parseFloat(motorRadio.dataset.hubPrice) || 0;
        if (shadePrice === 0) return 0;
        return (shadePrice * shadeCount) + hubPrice;
    }

    function calculateAll() {
        const rows = container.querySelectorAll('.cs-window-row');
        let totalSqft = 0;
        let shadeCount = 0;

        rows.forEach(row => {
            const w = parseFloat(row.querySelector('.cs-width').value) || 0;
            const h = parseFloat(row.querySelector('.cs-height').value) || 0;
            if (w > 0 && h > 0) {
                totalSqft += (w * h) / 144;
                shadeCount += 1;
            }
        });

        const tier = getCurrentTier(totalSqft);
        const useAlt = isUsingAltPrice();
        const ratePerSqft = tier ? (useAlt && tier.altPrice ? tier.altPrice : tier.price) : 0;
        const productSubtotal = totalSqft * ratePerSqft;
        const motorAddOn = getMotorTotal(shadeCount);
        const grandTotal = productSubtotal + motorAddOn;

        // Update tier display
        if (tierEl) {
            if (tier && totalSqft > 0) {
                tierEl.innerHTML = `
                    <span class="cs-tier-label">${tier.label} · ${Math.round(totalSqft)} sqft</span>
                    <span class="cs-tier-rate">$${ratePerSqft}/sqft</span>
                `;
            } else {
                tierEl.innerHTML = '<span class="cs-tier-label">Enter window dimensions to see your tier</span>';
            }
        }

        // Update total
        if (totalEl) {
            totalEl.textContent = grandTotal > 0 ? `$${Math.round(grandTotal).toLocaleString()}` : '$0';
            if (monthlyEl) {
                const monthly = grandTotal > 0 ? Math.round(grandTotal / 24) : 0;
                monthlyEl.textContent = monthly > 0 ? `$${monthly.toLocaleString()}` : '$0';
            }
        }
    }

    function createWindowRow(index) {
        const row = document.createElement('div');
        row.className = 'cs-window-row';
        row.dataset.windowIndex = index;
        row.innerHTML = `
            <div class="cs-window-header">
                <span class="cs-window-label">Window ${index + 1}</span>
                <button type="button" class="cs-remove-window" aria-label="Remove window">×</button>
            </div>
            <div class="cs-window-inputs">
                <div class="cs-input-group">
                    <label class="cs-input-label">Width (inches)</label>
                    <input type="number" class="cs-input cs-width" min="1" max="200" placeholder="36" />
                </div>
                <span class="cs-multiply">×</span>
                <div class="cs-input-group">
                    <label class="cs-input-label">Height (inches)</label>
                    <input type="number" class="cs-input cs-height" min="1" max="200" placeholder="48" />
                </div>
            </div>
        `;

        row.querySelector('.cs-remove-window').addEventListener('click', () => {
            row.remove();
            renumberWindows();
            calculateAll();
        });

        row.querySelectorAll('.cs-input').forEach(input => {
            input.addEventListener('input', calculateAll);
        });

        return row;
    }

    function renumberWindows() {
        const rows = container.querySelectorAll('.cs-window-row');
        rows.forEach((row, i) => {
            row.dataset.windowIndex = i;
            row.querySelector('.cs-window-label').textContent = `Window ${i + 1}`;
        });
        windowCount = rows.length;
    }

    function wireAddWindow() {
        if (!addBtn) return;
        addBtn.addEventListener('click', () => {
            const row = createWindowRow(windowCount);
            container.appendChild(row);
            windowCount++;
            row.querySelector('.cs-width').focus();
        });
    }

    wireAddWindow();

    section.querySelectorAll('.cs-input').forEach(input => {
        input.addEventListener('input', calculateAll);
    });
    section.querySelectorAll('.cs-radio').forEach(radio => {
        radio.addEventListener('change', calculateAll);
    });
})();
</script>

