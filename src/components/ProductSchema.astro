---
interface Props {
    name: string;
    description: string;
    url: string;
    image: string;
    lowPrice: string;
    highPrice?: string;
    priceCurrency?: string;
}

const { name, description, url, image, lowPrice, highPrice, priceCurrency = "USD" } = Astro.props;

const schema = {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": name,
    "description": description,
    "url": `https://www.boutiqueshutters.com${url}`,
    "image": `https://www.boutiqueshutters.com${image}`,
    "brand": {
        "@type": "Brand",
        "name": "Boutique Shutters"
    },
    "offers": {
        "@type": "AggregateOffer",
        "lowPrice": lowPrice,
        ...(highPrice && { "highPrice": highPrice }),
        "priceCurrency": priceCurrency,
        "availability": "https://schema.org/InStock",
        "seller": {
            "@type": "Organization",
            "name": "Boutique Shutters"
        }
    },
    "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "50",
        "bestRating": "5"
    }
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
