---
// Product Comparison Chart Component
---

<section id="comparison-chart">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">Compare Products</span>
            <h2 class="cs-title">Find Your Perfect Window Treatment</h2>
            <p class="cs-text">Not sure which product is right for your home? Compare our window treatment options side by side.</p>
        </div>

        <div class="cs-table-wrapper">
            <table class="cs-table">
                <thead>
                    <tr>
                        <th class="cs-feature-col">Feature</th>
                        <th><a href="/shutters">Plantation Shutters</a></th>
                        <th><a href="/zebra-shades">Zebra Shades</a></th>
                        <th><a href="/motorized-shades">Motorized Shades</a></th>
                        <th><a href="/exterior-shades">Exterior Shades</a></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="cs-feature">Starting Price</td>
                        <td><strong>$20/sq ft</strong></td>
                        <td><strong>$150/window</strong></td>
                        <td><strong>$300/window</strong></td>
                        <td><strong>Custom Quote</strong></td>
                    </tr>
                    <tr>
                        <td class="cs-feature">Best For</td>
                        <td>Traditional & modern homes</td>
                        <td>Contemporary, light control</td>
                        <td>Smart homes, convenience</td>
                        <td>Patios, sunrooms, outdoor</td>
                    </tr>
                    <tr>
                        <td class="cs-feature">Light Control</td>
                        <td><span class="cs-rating cs-rating-5">●●●●●</span></td>
                        <td><span class="cs-rating cs-rating-4">●●●●○</span></td>
                        <td><span class="cs-rating cs-rating-4">●●●●○</span></td>
                        <td><span class="cs-rating cs-rating-3">●●●○○</span></td>
                    </tr>
                    <tr>
                        <td class="cs-feature">Privacy</td>
                        <td><span class="cs-rating cs-rating-5">●●●●●</span></td>
                        <td><span class="cs-rating cs-rating-4">●●●●○</span></td>
                        <td><span class="cs-rating cs-rating-5">●●●●●</span></td>
                        <td><span class="cs-rating cs-rating-3">●●●○○</span></td>
                    </tr>
                    <tr>
                        <td class="cs-feature">Energy Efficiency</td>
                        <td><span class="cs-rating cs-rating-5">●●●●●</span></td>
                        <td><span class="cs-rating cs-rating-3">●●●○○</span></td>
                        <td><span class="cs-rating cs-rating-4">●●●●○</span></td>
                        <td><span class="cs-rating cs-rating-5">●●●●●</span></td>
                    </tr>
                    <tr>
                        <td class="cs-feature">Durability</td>
                        <td><span class="cs-rating cs-rating-5">●●●●●</span></td>
                        <td><span class="cs-rating cs-rating-3">●●●○○</span></td>
                        <td><span class="cs-rating cs-rating-4">●●●●○</span></td>
                        <td><span class="cs-rating cs-rating-5">●●●●●</span></td>
                    </tr>
                    <tr>
                        <td class="cs-feature">Smart Home</td>
                        <td>—</td>
                        <td>Optional</td>
                        <td>✓ Built-in</td>
                        <td>Optional</td>
                    </tr>
                    <tr>
                        <td class="cs-feature">Maintenance</td>
                        <td>Low — wipe clean</td>
                        <td>Low — dust occasionally</td>
                        <td>Very low — automated</td>
                        <td>Medium — outdoor care</td>
                    </tr>
                    <tr>
                        <td class="cs-feature">Home Value Impact</td>
                        <td><span class="cs-highlight">High ↑</span></td>
                        <td>Moderate</td>
                        <td>Moderate-High</td>
                        <td>Moderate</td>
                    </tr>
                    <tr>
                        <td class="cs-feature">Installation</td>
                        <td>2-3 weeks</td>
                        <td>1-2 weeks</td>
                        <td>2-3 weeks</td>
                        <td>2-4 weeks</td>
                    </tr>
                    <tr class="cs-cta-row">
                        <td></td>
                        <td><a href="/shutters" class="cs-table-link">Learn More →</a></td>
                        <td><a href="/zebra-shades" class="cs-table-link">Learn More →</a></td>
                        <td><a href="/motorized-shades" class="cs-table-link">Learn More →</a></td>
                        <td><a href="/exterior-shades" class="cs-table-link">Learn More →</a></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="cs-chart-cta">
            <p>Still not sure? Our design consultant will help you choose the perfect solution during your <strong>free consultation</strong>.</p>
            <a href="/book" class="cs-button-solid">Book Free Consultation</a>
        </div>
    </div>
</section>

<style lang="less">
/* Mobile - 360px */
@media only screen and (min-width: 0rem) {
    #comparison-chart {
        padding: var(--sectionPadding);

        .cs-container {
            width: 100%;
            max-width: (1280/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: clamp(1.5rem, 3vw, 2rem);
        }

        .cs-content {
            text-align: center;
            width: 100%;
            max-width: (700/16rem);
        }

        .cs-title {
            margin: 0 0 (16/16rem) 0;
        }

        .cs-table-wrapper {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .cs-table {
            width: 100%;
            min-width: (700/16rem);
            border-collapse: collapse;
            font-size: (14/16rem);

            th, td {
                padding: (12/16rem) (16/16rem);
                text-align: center;
                border-bottom: 1px solid #e8e8e8;
            }

            thead th {
                background: #1a1a1a;
                color: white;
                font-size: (13/16rem);
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                position: sticky;
                top: 0;

                a {
                    color: white;
                    text-decoration: none;

                    &:hover {
                        color: var(--secondary);
                    }
                }
            }

            .cs-feature-col {
                text-align: left;
                min-width: (120/16rem);
            }

            .cs-feature {
                text-align: left;
                font-weight: 700;
                color: var(--headerColor);
                font-size: (13/16rem);
                text-transform: uppercase;
                letter-spacing: 0.03em;
            }

            tbody tr {
                transition: background-color 0.2s;

                &:hover {
                    background-color: #f9f9f9;
                }

                &:nth-child(even) {
                    background-color: #fafafa;

                    &:hover {
                        background-color: #f5f5f5;
                    }
                }
            }

            td {
                color: var(--bodyTextColor);
                line-height: 1.5em;

                strong {
                    color: var(--secondary);
                    font-size: (15/16rem);
                }
            }
        }

        .cs-rating {
            letter-spacing: 0.1em;
            font-size: (12/16rem);
        }

        .cs-rating-5 { color: var(--secondary); }
        .cs-rating-4 { color: #d4a017; }
        .cs-rating-3 { color: #c0c0c0; }

        .cs-highlight {
            color: var(--secondary);
            font-weight: 700;
        }

        .cs-cta-row {
            td { border-bottom: none; }
        }

        .cs-table-link {
            font-size: (13/16rem);
            font-weight: 700;
            color: var(--secondary);
            text-decoration: none;
            transition: color 0.3s;

            &:hover {
                color: var(--csButtonHoverColor);
            }
        }

        .cs-chart-cta {
            text-align: center;
            max-width: (600/16rem);

            p {
                font-size: (16/16rem);
                line-height: 1.6em;
                color: var(--bodyTextColor);
                margin: 0 0 (16/16rem) 0;

                strong {
                    color: var(--headerColor);
                }
            }

            .cs-button-solid {
                font-size: (16/16rem);
                line-height: clamp(2.875rem, 5.5vw, 3.5rem);
                text-decoration: none;
                font-weight: 700;
                text-align: center;
                min-width: (200/16rem);
                padding: 0 (32/16rem);
                border-radius: (4/16rem);
                display: inline-block;
                position: relative;
                z-index: 1;
                color: var(--csButtonTextColor);

                &:before {
                    content: "";
                    position: absolute;
                    height: 100%;
                    width: 0%;
                    background: var(--csButtonHoverColor);
                    opacity: 1;
                    top: 0;
                    left: 0;
                    z-index: -1;
                    border-radius: (4/16rem);
                    transition: width 0.3s;
                }

                &:hover {
                    &:before {
                        width: 100%;
                    }
                }
            }
        }
    }
}
</style>
