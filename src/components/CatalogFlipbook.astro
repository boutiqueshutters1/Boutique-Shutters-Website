---
interface Catalog {
    id: string;
    name: string;
    pages: number;
    folder: string;
}

interface Props {
    catalogs: Catalog[];
    onSelectFabric?: boolean;
}

const { catalogs, onSelectFabric = false } = Astro.props;
const catalogDataJSON = JSON.stringify(catalogs);
---

<section id="catalog-flipbook">
    <div class="fb-container">
        <div class="fb-content">
            <span class="cs-topper">Browse Fabrics</span>
            <h2 class="cs-title">Fabric & Material Catalogs</h2>
            <p class="cs-text">Flip through our catalogs to explore fabric options, colors, and textures. Find the perfect material for your window treatments.</p>
        </div>

        <!-- Catalog Tabs -->
        <div class="fb-tabs">
            {catalogs.map((cat, i) => (
                <button class={`fb-tab ${i === 0 ? 'fb-tab-active' : ''}`} data-catalog-id={cat.id}>{cat.name}</button>
            ))}
        </div>

        <!-- Flipbook Viewer -->
        <div class="fb-viewer">
            <div class="fb-book" id="fb-book">
                <!-- Click zones: left half = prev, right half = next -->
                <div class="fb-click-zone fb-zone-prev" id="fb-zone-prev" title="Previous page">
                    <span class="fb-zone-arrow">‹</span>
                </div>
                <div class="fb-click-zone fb-zone-next" id="fb-zone-next" title="Next page">
                    <span class="fb-zone-arrow">›</span>
                </div>
                <div class="fb-spread">
                    <img class="fb-page fb-page-left" id="fb-page-img" src="" alt="Catalog page" />
                    <img class="fb-page fb-page-right" id="fb-page-img-right" src="" alt="Catalog page" />
                </div>
            </div>

            <!-- Controls -->
            <div class="fb-controls">
                <button class="fb-nav-btn" id="fb-prev" title="Previous page">‹</button>
                <span class="fb-page-info" id="fb-page-info">1 / 1</span>
                <button class="fb-nav-btn" id="fb-next" title="Next page">›</button>
            </div>

            <!-- Page thumbnails strip -->
            <div class="fb-thumbnails" id="fb-thumbnails"></div>

            {onSelectFabric && (
                <div class="fb-select-bar" id="fb-select-bar">
                    <p class="fb-select-text">See a fabric you like? Enter the code and select it.</p>
                    <div class="fb-select-form">
                        <input type="text" id="fb-fabric-code" class="fb-fabric-input" placeholder="Fabric code (e.g. WH-201)" />
                        <button class="fb-select-btn" id="fb-select-fabric">Select Fabric →</button>
                    </div>
                    <div class="fb-selected-list" id="fb-selected-list"></div>
                </div>
            )}
        </div>
    </div>
</section>

<script is:inline define:vars={{ catalogDataJSON }}>
(function() {
    const catalogs = JSON.parse(catalogDataJSON);
    let currentCatalog = catalogs[0];
    let currentPage = 1;

    const pageImg = document.getElementById('fb-page-img');
    const pageImgRight = document.getElementById('fb-page-img-right');
    const pageInfo = document.getElementById('fb-page-info');
    const thumbsContainer = document.getElementById('fb-thumbnails');

    function isSpreadMode() {
        return window.innerWidth >= 768;
    }
    const prevBtn = document.getElementById('fb-prev');
    const nextBtn = document.getElementById('fb-next');

    function getPageUrl(catalog, pageNum) {
        // Match actual file naming: 10+ pages use zero-padding, under 10 don't
        const padded = catalog.pages >= 10 ? String(pageNum).padStart(2, '0') : String(pageNum);
        return '/assets/catalogs/' + catalog.folder + '/page-' + padded + '.jpg';
    }

    function loadCatalog(catalog) {
        currentCatalog = catalog;
        currentPage = 1;

        // Update tabs
        document.querySelectorAll('.fb-tab').forEach(tab => {
            tab.classList.toggle('fb-tab-active', tab.dataset.catalogId === catalog.id);
        });

        // Build thumbnails
        let thumbsHTML = '';
        const maxThumbs = Math.min(catalog.pages, 20);
        for (let i = 1; i <= maxThumbs; i++) {
            thumbsHTML += '<button class="fb-thumb ' + (i === 1 ? 'fb-thumb-active' : '') + '" data-page="' + i + '">';
            thumbsHTML += '<img src="' + getPageUrl(catalog, i) + '" alt="Page ' + i + '" loading="lazy" />';
            thumbsHTML += '</button>';
        }
        if (catalog.pages > 20) {
            thumbsHTML += '<span class="fb-thumb-more">+' + (catalog.pages - 20) + ' more</span>';
        }
        thumbsContainer.innerHTML = thumbsHTML;

        showPage(1);
    }

    function showPage(num) {
        if (num < 1 || num > currentCatalog.pages) return;

        // In spread mode, snap to odd pages (left page is always odd)
        if (isSpreadMode() && num > 1) {
            num = num % 2 === 0 ? num - 1 : num;
        }

        currentPage = num;

        // Animate page transition
        pageImg.style.opacity = '0';
        pageImg.style.transform = 'scale(0.98)';
        pageImgRight.style.opacity = '0';
        pageImgRight.style.transform = 'scale(0.98)';

        setTimeout(() => {
            pageImg.src = getPageUrl(currentCatalog, num);
            pageImg.alt = currentCatalog.name + ' - Page ' + num;
            pageImg.style.opacity = '1';
            pageImg.style.transform = 'scale(1)';

            // Show right page in spread mode
            const rightPage = num + 1;
            if (isSpreadMode() && rightPage <= currentCatalog.pages) {
                pageImgRight.src = getPageUrl(currentCatalog, rightPage);
                pageImgRight.alt = currentCatalog.name + ' - Page ' + rightPage;
                pageImgRight.style.display = 'block';
                pageImgRight.style.opacity = '1';
                pageImgRight.style.transform = 'scale(1)';
            } else {
                pageImgRight.style.display = 'none';
            }
        }, 150);

        if (isSpreadMode() && num + 1 <= currentCatalog.pages) {
            pageInfo.textContent = num + '-' + (num + 1) + ' / ' + currentCatalog.pages;
        } else {
            pageInfo.textContent = num + ' / ' + currentCatalog.pages;
        }

        // Update prev/next states
        prevBtn.disabled = num <= 1;
        nextBtn.disabled = num >= currentCatalog.pages;

        // Update thumbnail active state
        document.querySelectorAll('.fb-thumb').forEach(thumb => {
            thumb.classList.toggle('fb-thumb-active', parseInt(thumb.dataset.page) === num);
        });

        // Scroll active thumbnail into view
        const activeThumb = document.querySelector('.fb-thumb-active');
        if (activeThumb) {
            activeThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
    }

    // Tab clicks
    document.querySelectorAll('.fb-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            const catalog = catalogs.find(c => c.id === tab.dataset.catalogId);
            if (catalog) loadCatalog(catalog);
        });
    });

    // Nav buttons — skip by 2 in spread mode
    function prevPage() { showPage(currentPage - (isSpreadMode() ? 2 : 1)); }
    function nextPage() { showPage(currentPage + (isSpreadMode() ? 2 : 1)); }
    prevBtn.addEventListener('click', prevPage);
    nextBtn.addEventListener('click', nextPage);

    // Click zones on the image
    document.getElementById('fb-zone-prev').addEventListener('click', prevPage);
    document.getElementById('fb-zone-next').addEventListener('click', nextPage);

    // Thumbnail clicks
    thumbsContainer.addEventListener('click', (e) => {
        const thumb = e.target.closest('.fb-thumb');
        if (thumb) showPage(parseInt(thumb.dataset.page));
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') prevPage();
        if (e.key === 'ArrowRight') nextPage();
    });

    // Select fabric button
    const selectBtn = document.getElementById('fb-select-fabric');
    const fabricCodeInput = document.getElementById('fb-fabric-code');
    const selectedList = document.getElementById('fb-selected-list');
    const selectedFabrics = [];

    if (selectBtn && fabricCodeInput) {
        selectBtn.addEventListener('click', () => {
            const code = fabricCodeInput.value.trim();
            if (!code) {
                fabricCodeInput.style.borderColor = '#e74c3c';
                fabricCodeInput.placeholder = 'Please enter a fabric code';
                setTimeout(() => {
                    fabricCodeInput.style.borderColor = '';
                    fabricCodeInput.placeholder = 'Fabric code (e.g. WH-201)';
                }, 2000);
                return;
            }

            const fabricRef = code + ' (' + currentCatalog.name + ', p.' + currentPage + ')';
            selectedFabrics.push({ code: code, catalog: currentCatalog.name, page: currentPage, reference: fabricRef });

            // Dispatch custom event for configurator
            window.dispatchEvent(new CustomEvent('fabricSelected', {
                detail: { catalog: currentCatalog.name, page: currentPage, code: code, reference: fabricRef, allSelections: selectedFabrics }
            }));

            // Update selected list
            renderSelectedList();

            // Reset input
            fabricCodeInput.value = '';

            // Visual feedback
            selectBtn.textContent = '✓ Added!';
            selectBtn.classList.add('fb-selected');
            setTimeout(() => {
                selectBtn.textContent = 'Select Fabric →';
                selectBtn.classList.remove('fb-selected');
            }, 1500);
        });

        // Allow Enter key to submit
        fabricCodeInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') { e.preventDefault(); selectBtn.click(); }
        });
    }

    function renderSelectedList() {
        if (!selectedList) return;
        if (selectedFabrics.length === 0) { selectedList.innerHTML = ''; return; }

        let html = '<div class="fb-selected-header">Selected Fabrics:</div>';
        selectedFabrics.forEach((fab, i) => {
            html += '<div class="fb-selected-item">';
            html += '<span class="fb-selected-code">' + fab.code + '</span>';
            html += '<span class="fb-selected-ref">' + fab.catalog + ', p.' + fab.page + '</span>';
            html += '<button class="fb-selected-remove" data-index="' + i + '">✕</button>';
            html += '</div>';
        });
        selectedList.innerHTML = html;
    }

    // Remove fabric from list
    if (selectedList) {
        selectedList.addEventListener('click', (e) => {
            const removeBtn = e.target.closest('.fb-selected-remove');
            if (!removeBtn) return;
            const idx = parseInt(removeBtn.dataset.index);
            selectedFabrics.splice(idx, 1);
            renderSelectedList();
            // Update configurator
            window.dispatchEvent(new CustomEvent('fabricSelected', {
                detail: { allSelections: selectedFabrics, reference: selectedFabrics.map(f => f.reference).join('; ') }
            }));
        });
    }

    // Touch swipe support
    let touchStartX = 0;
    const book = document.getElementById('fb-book');
    book.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    book.addEventListener('touchend', (e) => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
            if (diff > 0) showPage(currentPage + 1); // swipe left = next
            else showPage(currentPage - 1); // swipe right = prev
        }
    });

    // Initialize
    loadCatalog(catalogs[0]);
})();
</script>

<style lang="less">
@media only screen and (min-width: 0rem) {
    #catalog-flipbook {
        padding: var(--sectionPadding);
        background: #f7f7f7;

        .fb-container {
            width: 100%;
            max-width: (1280/16rem);
            margin: auto;
        }

        .fb-content {
            text-align: center;
            margin-bottom: clamp(1.5rem, 3vw, 2rem);
        }

        .cs-title { margin: 0 0 (8/16rem) 0; }

        /* Tabs */
        .fb-tabs {
            display: flex;
            justify-content: center;
            gap: (8/16rem);
            margin-bottom: (20/16rem);
            flex-wrap: wrap;
        }

        .fb-tab {
            font-family: inherit;
            font-size: (13/16rem);
            font-weight: 700;
            padding: (8/16rem) (16/16rem);
            border: 2px solid #e0e0e0;
            background: white;
            color: #666;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: all 0.3s;

            &:hover { border-color: var(--secondary); color: var(--secondary); }

            &.fb-tab-active {
                background: var(--secondary);
                border-color: var(--secondary);
                color: #000;
            }
        }

        /* Viewer */
        .fb-viewer {
            max-width: (800/16rem);
            margin: 0 auto;
        }

        .fb-book {
            background: white;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1), 0 0 0 1px rgba(0,0,0,0.05);
            overflow: hidden;
            position: relative;
            min-height: (300/16rem);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .fb-click-zone {
            position: absolute;
            top: 0;
            width: 40%;
            height: 100%;
            z-index: 2;
            cursor: pointer;
            display: flex;
            align-items: center;
            transition: background 0.2s;

            &:hover {
                background: rgba(0, 0, 0, 0.04);

                .fb-zone-arrow {
                    opacity: 1;
                }
            }
        }

        .fb-zone-prev {
            left: 0;
            justify-content: flex-start;
            padding-left: (12/16rem);
        }

        .fb-zone-next {
            right: 0;
            justify-content: flex-end;
            padding-right: (12/16rem);
        }

        .fb-zone-arrow {
            font-size: (36/16rem);
            font-weight: 700;
            color: #1a1a1a;
            background: rgba(255, 255, 255, 0.85);
            width: (44/16rem);
            height: (44/16rem);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.2s;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }

        .fb-spread {
            display: flex;
            width: 100%;
        }

        .fb-page {
            width: 100%;
            height: auto;
            display: block;
            transition: opacity 0.15s, transform 0.15s;
            user-select: none;
            -webkit-user-drag: none;
        }

        .fb-page-right {
            display: none;
        }

        /* Controls */
        .fb-controls {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: (16/16rem);
            padding: (16/16rem) 0;
        }

        .fb-nav-btn {
            width: (44/16rem);
            height: (44/16rem);
            border: 2px solid #e0e0e0;
            background: white;
            font-size: (24/16rem);
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            border-radius: 50%;

            &:hover:not(:disabled) {
                border-color: var(--secondary);
                background: var(--secondary);
                color: #000;
            }

            &:disabled {
                opacity: 0.3;
                cursor: not-allowed;
            }
        }

        .fb-page-info {
            font-size: (14/16rem);
            font-weight: 600;
            color: #666;
            min-width: (60/16rem);
            text-align: center;
        }

        /* Thumbnails */
        .fb-thumbnails {
            display: flex;
            gap: (8/16rem);
            overflow-x: auto;
            padding: (8/16rem) 0 (16/16rem);
            scrollbar-width: thin;

            &::-webkit-scrollbar {
                height: 4px;
            }

            &::-webkit-scrollbar-thumb {
                background: #ccc;
                border-radius: 2px;
            }
        }

        .fb-thumb {
            flex-shrink: 0;
            width: (60/16rem);
            height: (80/16rem);
            border: 2px solid #e0e0e0;
            padding: 0;
            background: white;
            cursor: pointer;
            overflow: hidden;
            transition: border-color 0.3s;

            &:hover { border-color: var(--secondary); }

            &.fb-thumb-active {
                border-color: var(--secondary);
                box-shadow: 0 0 0 2px var(--secondary);
            }

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }
        }

        .fb-thumb-more {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            font-size: (12/16rem);
            font-weight: 600;
            color: #999;
            padding: 0 (8/16rem);
        }

        /* Select Fabric Bar */
        .fb-select-bar {
            padding: (16/16rem);
            background: #1a1a1a;
        }

        .fb-select-text {
            font-size: (14/16rem);
            color: #e0e0e0;
            margin: 0 0 (10/16rem) 0;
        }

        .fb-select-form {
            display: flex;
            gap: (8/16rem);
            margin-bottom: (8/16rem);
        }

        .fb-fabric-input {
            flex: 1;
            font-family: inherit;
            font-size: (14/16rem);
            padding: (8/16rem) (12/16rem);
            border: 2px solid #444;
            background: #2a2a2a;
            color: white;
            transition: border-color 0.3s;

            &:focus {
                outline: none;
                border-color: var(--secondary);
            }

            &::placeholder {
                color: #888;
            }
        }

        .fb-selected-list {
            margin-top: (8/16rem);
        }

        .fb-selected-header {
            font-size: (12/16rem);
            font-weight: 600;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: (6/16rem);
        }

        .fb-selected-item {
            display: flex;
            align-items: center;
            gap: (8/16rem);
            padding: (6/16rem) 0;
            border-bottom: 1px solid #333;
        }

        .fb-selected-code {
            font-size: (14/16rem);
            font-weight: 700;
            color: var(--secondary);
        }

        .fb-selected-ref {
            font-size: (12/16rem);
            color: #888;
            flex: 1;
        }

        .fb-selected-remove {
            font-family: inherit;
            font-size: (12/16rem);
            padding: (2/16rem) (6/16rem);
            border: 1px solid #555;
            background: transparent;
            color: #888;
            cursor: pointer;
            transition: all 0.2s;

            &:hover {
                border-color: #e74c3c;
                color: #e74c3c;
            }
        }

        .fb-select-btn {
            font-family: inherit;
            font-size: (14/16rem);
            font-weight: 700;
            padding: (8/16rem) (20/16rem);
            border: none;
            background: var(--secondary);
            color: #000;
            cursor: pointer;
            transition: all 0.3s;
            white-space: nowrap;

            &:hover { background: var(--csButtonHoverColor); }

            &.fb-selected {
                background: #2ecc71;
                color: white;
            }
        }
    }
}

/* Tablet — spread mode */
@media only screen and (min-width: 48rem) {
    #catalog-flipbook {
        .fb-spread {
            display: flex;
        }

        .fb-page-left, .fb-page-right {
            width: 50%;
            flex-shrink: 0;
        }

        .fb-page-right {
            border-left: 1px solid #e0e0e0;
        }

        .fb-book {
            box-shadow: 0 4px 30px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,0,0,0.08);
        }

        .fb-thumb {
            width: (80/16rem);
            height: (100/16rem);
        }
    }
}
</style>
