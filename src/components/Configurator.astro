---
import productsData from "@data/products.json";
const products = productsData.products;
const productDataJSON = JSON.stringify(products);
---

<section id="configurator">
    <div class="cfg-container">
        <!-- Progress Bar -->
        <div class="cfg-progress">
            <div class="cfg-step-indicator cfg-active" data-step="1">
                <span class="cfg-step-num">1</span>
                <span class="cfg-step-label">Product</span>
            </div>
            <div class="cfg-step-line"></div>
            <div class="cfg-step-indicator" data-step="2">
                <span class="cfg-step-num">2</span>
                <span class="cfg-step-label">Size</span>
            </div>
            <div class="cfg-step-line"></div>
            <div class="cfg-step-indicator" data-step="3">
                <span class="cfg-step-num">3</span>
                <span class="cfg-step-label">Options</span>
            </div>
            <div class="cfg-step-line"></div>
            <div class="cfg-step-indicator" data-step="4">
                <span class="cfg-step-num">4</span>
                <span class="cfg-step-label">Review</span>
            </div>
            <div class="cfg-step-line"></div>
            <div class="cfg-step-indicator" data-step="5">
                <span class="cfg-step-num">5</span>
                <span class="cfg-step-label">Cart</span>
            </div>
        </div>

        <!-- Step 1: Select Product -->
        <div class="cfg-panel" id="cfg-step-1">
            <h2 class="cfg-title">Choose Your Window Treatment</h2>
            <p class="cfg-subtitle">Select a product type to begin customizing</p>
            <div class="cfg-product-grid">
                {products.map((p) => (
                    <button class="cfg-product-card" data-product-id={p.id}>
                        <img src={p.image} alt={p.name} loading="lazy" decoding="async" />
                        <div class="cfg-product-info">
                            <h3>{p.name}</h3>
                            <p>{p.description}</p>
                            {p.checkoutEnabled ? (
                                <span class="cfg-price-badge">From ${p.subtypes ? p.subtypes[0].basePrice : p.basePrice}</span>
                            ) : (
                                <span class="cfg-price-badge cfg-contact">Contact for Pricing</span>
                            )}
                        </div>
                    </button>
                ))}
            </div>
        </div>

        <!-- Step 2: Choose Fabric (only for products requiring fabric code) -->
        <div class="cfg-panel cfg-hidden" id="cfg-step-fabric">
            <h2 class="cfg-title">Choose Your Fabric</h2>
            <p class="cfg-subtitle">Browse the catalog below and tap a page to enter the fabric code you'd like</p>

            <div class="cfg-fabric-status" id="cfg-fabric-status">
                <div class="cfg-fabric-empty" id="cfg-fabric-empty">
                    <span class="cfg-fabric-icon">👇</span>
                    <p>Scroll down to browse the fabric catalog. Tap any page to select a fabric code.</p>
                </div>
                <div class="cfg-fabric-selected cfg-hidden" id="cfg-fabric-selected">
                    <span class="cfg-fabric-check">✓</span>
                    <div class="cfg-fabric-info">
                        <span class="cfg-fabric-code-display" id="cfg-fabric-code-display">—</span>
                        <span class="cfg-fabric-ref" id="cfg-fabric-ref-display">—</span>
                    </div>
                    <button class="cfg-fabric-change" id="cfg-fabric-change">Change</button>
                </div>
            </div>

            <div class="cfg-nav-buttons">
                <button class="cfg-btn-back" data-goto="1">← Back</button>
                <button class="cfg-btn-next cfg-btn-disabled" id="cfg-fabric-next">Next: Size & Quantity →</button>
            </div>
        </div>

        <!-- Step 3: Size (was Step 2) -->
        <div class="cfg-panel cfg-hidden" id="cfg-step-2">
            <h2 class="cfg-title">Enter Window Measurements</h2>
            <p class="cfg-subtitle">Measure your window opening to the nearest 1/8 inch</p>

            <div class="cfg-subtype-selector cfg-hidden" id="cfg-subtype-row">
                <label class="cfg-label">Select Type</label>
                <div class="cfg-pill-group" id="cfg-subtypes"></div>
            </div>

            <div class="cfg-size-form">
                <div class="cfg-size-group">
                    <label class="cfg-label">Width (inches)</label>
                    <div class="cfg-size-inputs">
                        <input type="number" id="cfg-width-whole" min="12" max="96" placeholder="36" class="cfg-input" />
                        <select id="cfg-width-frac" class="cfg-select">
                            <option value="0">0</option>
                            <option value="0.125">1/8</option>
                            <option value="0.25">1/4</option>
                            <option value="0.375">3/8</option>
                            <option value="0.5">1/2</option>
                            <option value="0.625">5/8</option>
                            <option value="0.75">3/4</option>
                            <option value="0.875">7/8</option>
                        </select>
                    </div>
                </div>
                <div class="cfg-size-group">
                    <label class="cfg-label">Height (inches)</label>
                    <div class="cfg-size-inputs">
                        <input type="number" id="cfg-height-whole" min="12" max="96" placeholder="48" class="cfg-input" />
                        <select id="cfg-height-frac" class="cfg-select">
                            <option value="0">0</option>
                            <option value="0.125">1/8</option>
                            <option value="0.25">1/4</option>
                            <option value="0.375">3/8</option>
                            <option value="0.5">1/2</option>
                            <option value="0.625">5/8</option>
                            <option value="0.75">3/4</option>
                            <option value="0.875">7/8</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="cfg-size-preview" id="cfg-size-preview">
                <div class="cfg-preview-box" id="cfg-preview-box"></div>
                <span class="cfg-preview-dims" id="cfg-preview-dims">-- × -- in</span>
            </div>

            <div class="cfg-quantity-row">
                <label class="cfg-label">Quantity</label>
                <div class="cfg-qty-control">
                    <button class="cfg-qty-btn" id="cfg-qty-minus">−</button>
                    <input type="number" id="cfg-quantity" value="1" min="1" max="50" class="cfg-qty-input" />
                    <button class="cfg-qty-btn" id="cfg-qty-plus">+</button>
                </div>
            </div>

            <div class="cfg-nav-buttons">
                <button class="cfg-btn-back" data-goto="1">← Back</button>
                <button class="cfg-btn-next" id="cfg-size-next">Next: Options →</button>
            </div>
        </div>

        <!-- Step 3: Options -->
        <div class="cfg-panel cfg-hidden" id="cfg-step-3">
            <h2 class="cfg-title">Customize Your Options</h2>
            <p class="cfg-subtitle">Select your preferences — preview updates live</p>
            <div class="cfg-options-layout">
                <!-- Live Preview -->
                <div class="cfg-preview-panel" id="cfg-live-preview">
                    <div class="cfg-preview-window">
                        <!-- Catalog page image as preview -->
                        <div class="cfg-preview-img-wrap">
                            <img class="cfg-preview-catalog-img" id="cfg-preview-img" src="" alt="Selected fabric preview" />
                            <div class="cfg-preview-no-fabric" id="cfg-preview-no-fabric">
                                <span>📋</span>
                                <p>Select a fabric to see the catalog preview</p>
                            </div>
                        </div>
                        <!-- Selected options summary below image -->
                        <div class="cfg-preview-options" id="cfg-preview-options"></div>
                    </div>
                </div>

                <!-- Options -->
                <div class="cfg-options-form" id="cfg-options-container"></div>
            </div>
            <div class="cfg-nav-buttons">
                <button class="cfg-btn-back" data-goto="2">← Back</button>
                <button class="cfg-btn-next" id="cfg-options-next">Next: Review →</button>
            </div>
        </div>

        <!-- Step 4: Review -->
        <div class="cfg-panel cfg-hidden" id="cfg-step-4">
            <h2 class="cfg-title">Review Your Configuration</h2>
            <p class="cfg-subtitle">Confirm your selections before adding to cart</p>
            <div class="cfg-review-card" id="cfg-review-card"></div>
            <div class="cfg-nav-buttons">
                <button class="cfg-btn-back" data-goto="3">← Back</button>
                <button class="cfg-btn-next" id="cfg-review-next">Add to Cart →</button>
            </div>
        </div>

        <!-- Step 5: Cart -->
        <div class="cfg-panel cfg-hidden" id="cfg-step-5">
            <div class="cfg-cart-success" id="cfg-cart-area">
                <!-- Filled dynamically -->
            </div>
        </div>

        <!-- Sticky Price Bar -->
        <div class="cfg-price-bar cfg-hidden" id="cfg-price-bar">
            <div class="cfg-price-bar-inner">
                <span class="cfg-price-bar-label" id="cfg-bar-product">—</span>
                <span class="cfg-price-bar-total" id="cfg-bar-price">$0</span>
            </div>
        </div>
    </div>
</section>

<script is:inline define:vars={{ productDataJSON }}>
(function() {
    const products = JSON.parse(productDataJSON);

    // State
    const state = {
        step: 1,
        productId: null,
        product: null,
        subtypeId: null,
        widthWhole: null,
        widthFrac: 0,
        heightWhole: null,
        heightFrac: 0,
        quantity: 1,
        options: {},
        fabricCode: null,
        fabricReference: null
    };

    // Step mapping: product-aware step sequences
    // Products with requiresFabricCode get: 1(product) → fabric → 2(size) → 3(options) → 4(review) → 5(cart)
    // Products without: 1(product) → 2(size) → 3(options) → 4(review) → 5(cart)
    const stepPanelIds = ['cfg-step-1', 'cfg-step-fabric', 'cfg-step-2', 'cfg-step-3', 'cfg-step-4', 'cfg-step-5'];

    function getStepSequence() {
        if (state.product && state.product.requiresFabricCode) {
            return [1, 'fabric', 2, 3, 4, 5]; // 6 steps
        }
        return [1, 2, 3, 4, 5]; // 5 steps (no fabric)
    }

    // DOM refs
    const allPanels = {};
    stepPanelIds.forEach(id => { allPanels[id] = document.getElementById(id); });
    const indicators = document.querySelectorAll('.cfg-step-indicator');
    const priceBar = document.getElementById('cfg-price-bar');
    const barProduct = document.getElementById('cfg-bar-product');
    const barPrice = document.getElementById('cfg-bar-price');

    // --- Navigation ---
    function goToStep(n) {
        state.step = n;

        // Hide all panels, show the right one
        const panelId = n === 'fabric' ? 'cfg-step-fabric' : 'cfg-step-' + n;
        Object.values(allPanels).forEach(p => { if (p) p.classList.add('cfg-hidden'); });
        if (allPanels[panelId]) allPanels[panelId].classList.remove('cfg-hidden');

        // Update progress indicators
        const seq = getStepSequence();
        const currentIdx = seq.indexOf(n);
        indicators.forEach(ind => {
            const s = parseInt(ind.dataset.step);
            // Map indicator 1-5 to sequence position
            const indIdx = s - 1;
            ind.classList.toggle('cfg-active', indIdx === currentIdx);
            ind.classList.toggle('cfg-done', indIdx < currentIdx);
        });

        priceBar.classList.toggle('cfg-hidden', n === 1);
        updatePriceBar();
        window.scrollTo({ top: document.getElementById('configurator').offsetTop - 100, behavior: 'smooth' });

        if (n === 'fabric') {
            // Auto-jump catalog to the right section
            if (state.product.catalogSection) {
                window.dispatchEvent(new CustomEvent('catalogJump', {
                    detail: state.product.catalogSection
                }));
            }
        }
        if (n === 3) { renderOptions(); updateLivePreview(); }
        if (n === 4) renderReview();
        if (n === 5) renderCart();
    }

    // Back buttons — handle named steps
    document.querySelectorAll('.cfg-btn-back').forEach(btn => {
        btn.addEventListener('click', () => {
            const target = btn.dataset.goto;
            if (target === 'fabric') {
                goToStep('fabric');
            } else {
                const num = parseInt(target);
                // If going back to step 2 (size) and product has fabric, go to fabric instead
                if (num === 2 && state.product && state.product.requiresFabricCode) {
                    // Check if we're coming from step 3 (options) — go to size (2)
                    // or from step 2 (size) — go to fabric
                    goToStep(num);
                } else {
                    goToStep(num);
                }
            }
        });
    });

    // --- Step 1: Product Selection ---
    document.querySelectorAll('.cfg-product-card').forEach(card => {
        card.addEventListener('click', () => {
            const id = card.dataset.productId;
            state.productId = id;
            state.product = products.find(p => p.id === id);
            state.options = {};
            state.subtypeId = null;

            // Set defaults for each option group
            if (state.product.options) {
                Object.keys(state.product.options).forEach(key => {
                    if (state.product.options[key].length > 0) {
                        state.options[key] = state.product.options[key][0].id;
                    }
                });
            }

            // Show subtype selector if applicable
            const subtypeRow = document.getElementById('cfg-subtype-row');
            const subtypeContainer = document.getElementById('cfg-subtypes');
            if (state.product.subtypes && state.product.subtypes.length > 0) {
                state.subtypeId = state.product.subtypes[0].id;
                subtypeContainer.innerHTML = state.product.subtypes.map(st =>
                    `<button class="cfg-pill ${st.id === state.subtypeId ? 'cfg-pill-active' : ''}" data-subtype="${st.id}">${st.name} — $${st.basePrice}</button>`
                ).join('');
                subtypeRow.classList.remove('cfg-hidden');
            } else {
                subtypeRow.classList.add('cfg-hidden');
            }

            // Update size constraints
            const sc = state.product.sizeConstraints;
            document.getElementById('cfg-width-whole').min = sc.minW;
            document.getElementById('cfg-width-whole').max = sc.maxW;
            document.getElementById('cfg-height-whole').min = sc.minH;
            document.getElementById('cfg-height-whole').max = sc.maxH;

            // Reset fabric state
            state.fabricCode = null;
            state.fabricReference = null;
            document.getElementById('cfg-fabric-empty').classList.remove('cfg-hidden');
            document.getElementById('cfg-fabric-selected').classList.add('cfg-hidden');
            document.getElementById('cfg-fabric-next').classList.add('cfg-btn-disabled');

            // Route to fabric step or size step
            if (state.product.requiresFabricCode) {
                goToStep('fabric');
            } else {
                goToStep(2);
            }
        });
    });

    // Subtype selection
    document.getElementById('cfg-subtypes').addEventListener('click', (e) => {
        const pill = e.target.closest('.cfg-pill');
        if (!pill) return;
        state.subtypeId = pill.dataset.subtype;
        document.querySelectorAll('#cfg-subtypes .cfg-pill').forEach(p => p.classList.remove('cfg-pill-active'));
        pill.classList.add('cfg-pill-active');
        updatePriceBar();
    });

    // --- Step 2: Size ---
    const wWhole = document.getElementById('cfg-width-whole');
    const wFrac = document.getElementById('cfg-width-frac');
    const hWhole = document.getElementById('cfg-height-whole');
    const hFrac = document.getElementById('cfg-height-frac');
    const previewBox = document.getElementById('cfg-preview-box');
    const previewDims = document.getElementById('cfg-preview-dims');

    function updateSizePreview() {
        state.widthWhole = parseInt(wWhole.value) || 0;
        state.widthFrac = parseFloat(wFrac.value) || 0;
        state.heightWhole = parseInt(hWhole.value) || 0;
        state.heightFrac = parseFloat(hFrac.value) || 0;
        const w = state.widthWhole + state.widthFrac;
        const h = state.heightWhole + state.heightFrac;

        if (w > 0 && h > 0) {
            const maxDim = 200;
            const ratio = w / h;
            let boxW, boxH;
            if (ratio > 1) { boxW = maxDim; boxH = maxDim / ratio; }
            else { boxH = maxDim; boxW = maxDim * ratio; }
            previewBox.style.width = boxW + 'px';
            previewBox.style.height = boxH + 'px';

            const wDisplay = state.widthFrac > 0 ? w.toFixed(3).replace(/0+$/, '').replace(/\.$/, '') : w;
            const hDisplay = state.heightFrac > 0 ? h.toFixed(3).replace(/0+$/, '').replace(/\.$/, '') : h;
            previewDims.textContent = wDisplay + '" × ' + hDisplay + '"';
        }
        updatePriceBar();
    }

    [wWhole, wFrac, hWhole, hFrac].forEach(el => el.addEventListener('input', updateSizePreview));
    [wFrac, hFrac].forEach(el => el.addEventListener('change', updateSizePreview));

    // Quantity
    const qtyInput = document.getElementById('cfg-quantity');
    document.getElementById('cfg-qty-minus').addEventListener('click', () => {
        state.quantity = Math.max(1, (parseInt(qtyInput.value) || 1) - 1);
        qtyInput.value = state.quantity;
        updatePriceBar();
    });
    document.getElementById('cfg-qty-plus').addEventListener('click', () => {
        state.quantity = Math.min(50, (parseInt(qtyInput.value) || 1) + 1);
        qtyInput.value = state.quantity;
        updatePriceBar();
    });
    qtyInput.addEventListener('input', () => {
        state.quantity = Math.max(1, Math.min(50, parseInt(qtyInput.value) || 1));
        updatePriceBar();
    });

    // Size Next
    // --- Fabric Step ---
    const fabricNextBtn = document.getElementById('cfg-fabric-next');
    const fabricChangeBtn = document.getElementById('cfg-fabric-change');

    // Listen for fabric selection from CatalogFlipbook
    window.addEventListener('fabricSelected', function(e) {
        if (!e.detail.code) return;
        state.fabricCode = e.detail.code;
        state.fabricReference = e.detail.reference;

        // Update fabric status display
        document.getElementById('cfg-fabric-empty').classList.add('cfg-hidden');
        document.getElementById('cfg-fabric-selected').classList.remove('cfg-hidden');
        document.getElementById('cfg-fabric-code-display').textContent = e.detail.code;
        document.getElementById('cfg-fabric-ref-display').textContent = e.detail.catalog + ', Page ' + e.detail.page;

        // Enable next button
        fabricNextBtn.classList.remove('cfg-btn-disabled');

        // Scroll back up to configurator
        window.scrollTo({ top: document.getElementById('configurator').offsetTop - 100, behavior: 'smooth' });
    });

    fabricNextBtn.addEventListener('click', () => {
        if (!state.fabricCode) {
            alert('Please select a fabric code from the catalog below before continuing.');
            return;
        }
        goToStep(2); // Go to size step
    });

    if (fabricChangeBtn) {
        fabricChangeBtn.addEventListener('click', () => {
            // Scroll down to catalog
            const catalog = document.getElementById('catalog-flipbook');
            if (catalog) catalog.scrollIntoView({ behavior: 'smooth' });
        });
    }

    document.getElementById('cfg-size-next').addEventListener('click', () => {
        const w = (state.widthWhole || 0) + state.widthFrac;
        const h = (state.heightWhole || 0) + state.heightFrac;
        const sc = state.product.sizeConstraints;
        if (w < sc.minW || w > sc.maxW || h < sc.minH || h > sc.maxH) {
            alert('Please enter valid dimensions. Width: ' + sc.minW + '-' + sc.maxW + '", Height: ' + sc.minH + '-' + sc.maxH + '"');
            return;
        }
        goToStep(3);
    });

    // --- Step 3: Options (Accordion with visual cards, tooltips, price impact, recommended) ---

    // Option metadata: tooltips, recommended, icons
    const optMeta = {
        mount: {
            icon: '📐', order: 1,
            tips: { inside: 'Fits inside the window frame for a clean, flush look', outside: 'Mounts above the frame — great for covering gaps or making windows appear larger' },
            recommended: 'inside'
        },
        valanceStyle: {
            icon: '🏗️', order: 2,
            tips: { 'premium-square': 'Largest, most premium look with clean lines', 'large-square': 'Modern square profile, popular choice', 'large-round': 'Softer curved profile, elegant look', 'small-round': 'Compact and minimal', 'small-square': 'Smallest footprint, budget-friendly', 'basic-rail': 'No valance cover, exposed mechanism' },
            recommended: 'large-square'
        },
        movement: {
            icon: '⚙️', order: 3,
            tips: { chain: 'Classic chain loop — reliable and affordable', cordless: 'No chains or cords — clean look, child & pet safe', wand: 'Twist wand control — child safe, no dangling cords', motorized: 'Remote + app + voice control — the ultimate convenience' },
            recommended: 'cordless'
        },
        chainColor: {
            icon: '🔗', order: 4,
            tips: { steel: 'Durable metal finish', white: 'Blends with white frames', black: 'Bold contrast accent', transparent: 'Nearly invisible' },
            conditional: { dependsOn: 'movement', showWhen: 'chain' }
        },
        bottomBar: {
            icon: '📏', order: 5,
            tips: { narrow: 'Slim and minimal profile', basic: 'Standard width, most common', square: 'Wider, more substantial look' },
            recommended: 'basic'
        },
        fabric: {
            icon: '🧵', order: 2,
            tips: { 'light-filtering': 'Lets soft light through while reducing glare', blackout: 'Blocks 99% of light — ideal for bedrooms', solar: 'UV protection while maintaining your view' }
        },
        color: { icon: '🎨', order: 6 },
        valanceColor: {
            icon: '🎨', order: 7,
            tips: { white: 'Clean, classic — matches most trim', ivory: 'Warm off-white, less stark', gray: 'Modern neutral', brown: 'Warm wood-tone complement', black: 'Bold, dramatic accent' }
        },
        bottomRailColor: {
            icon: '🎨', order: 8,
            tips: { white: 'Matches white valance', ivory: 'Warm tone', gray: 'Contemporary', brown: 'Natural warmth', black: 'Statement contrast' },
            recommended: 'white'
        },
        slatSize: { icon: '📏', order: 2, tips: { '2in': 'Classic look, more privacy', '2.5in': 'Modern look, more light', '25mm': 'Slim traditional', '35mm': 'Mid-size versatile', '50mm': 'Wide statement slats' } },
        cordless: { icon: '🔒', order: 3, tips: { standard: 'Traditional cord lift', cordless: 'Child-safe, clean look' }, recommended: 'cordless' },
        motorized: { icon: '⚡', order: 3, tips: { manual: 'Standard manual operation', motorized: 'App, voice & remote control' } },
        motorProtocol: { icon: '📡', order: 4, tips: { wifi: 'Works with most home Wi-Fi', zigbee: 'Low power, needs hub', matter: 'Latest standard, works with everything' } },
        operation: { icon: '⚙️', order: 3 },
        foldStyle: { icon: '📐', order: 2, tips: { flat: 'Clean flat panels when raised', hobbled: 'Soft cascading folds', balloon: 'Full gathered puffs' } },
        lining: { icon: '🌙', order: 3, tips: { unlined: 'Light and airy, some light passes through', privacy: 'Blocks view but lets diffused light in', blackout: 'Total darkness — best for bedrooms' } }
    };

    const optLabels = {
        mount: 'Mount Type', slatSize: 'Slat Size', color: 'Shade Color',
        cordless: 'Lift System', fabric: 'Fabric Type', motorized: 'Operation',
        motorProtocol: 'Motor Protocol', operation: 'Operation',
        valanceStyle: 'Valance Style', movement: 'Movement / Lift',
        chainColor: 'Chain Color', bottomBar: 'Bottom Bar',
        valanceColor: 'Valance Color', bottomRailColor: 'Bottom Rail Color',
        foldStyle: 'Fold Style', lining: 'Lining'
    };

    function renderOptions() {
        const container = document.getElementById('cfg-options-container');
        const opts = state.product.options;
        if (!opts) { container.innerHTML = '<p>No additional options for this product.</p>'; return; }

        // Sort option keys by order
        const sortedKeys = Object.keys(opts).sort((a, b) => {
            return ((optMeta[a] || {}).order || 99) - ((optMeta[b] || {}).order || 99);
        });

        // Count total and completed options
        const visibleKeys = sortedKeys.filter(key => {
            const meta = optMeta[key] || {};
            if (meta.conditional) return state.options[meta.conditional.dependsOn] === meta.conditional.showWhen;
            return true;
        });
        const completedCount = visibleKeys.filter(k => state.options[k]).length;

        let html = '';

        // Progress bar
        html += '<div class="cfg-opts-progress">';
        html += '<span class="cfg-opts-progress-text">' + completedCount + ' of ' + visibleKeys.length + ' options selected</span>';
        html += '<div class="cfg-opts-progress-bar"><div class="cfg-opts-progress-fill" style="width:' + Math.round(completedCount / visibleKeys.length * 100) + '%"></div></div>';
        html += '</div>';

        // Running total
        const price = calculatePrice();
        const total = price * state.quantity;
        if (state.product.checkoutEnabled && total > 0) {
            html += '<div class="cfg-opts-total">Running Total: <strong>$' + total.toFixed(2) + '</strong></div>';
        }

        // Fabric code display
        if (state.product.requiresFabricCode && state.fabricCode) {
            html += '<div class="cfg-accordion cfg-accordion-done">';
            html += '<div class="cfg-accordion-header"><span>🏷️ Selected Fabric</span><span class="cfg-accordion-value">' + state.fabricCode + '</span></div>';
            html += '</div>';
        }

        // Accordion sections
        sortedKeys.forEach((key, idx) => {
            const meta = optMeta[key] || {};

            // Conditional visibility
            if (meta.conditional) {
                if (state.options[meta.conditional.dependsOn] !== meta.conditional.showWhen) return;
            }

            const group = opts[key];
            const label = optLabels[key] || key;
            const icon = meta.icon || '⚙️';
            const isColor = key === 'color' || key === 'valanceColor' || key === 'bottomRailColor';
            const selectedOpt = group.find(o => o.id === state.options[key]);
            const selectedName = selectedOpt ? selectedOpt.name : 'Select...';
            const isDone = !!state.options[key];

            html += '<div class="cfg-accordion ' + (isDone ? 'cfg-accordion-done' : '') + '" data-accordion="' + key + '">';

            // Header (clickable to expand/collapse)
            html += '<button class="cfg-accordion-header" data-toggle="' + key + '">';
            html += '<span>' + icon + ' ' + label + '</span>';
            html += '<span class="cfg-accordion-value">' + (isDone ? selectedName : '<em>Select</em>') + ' <span class="cfg-accordion-arrow">▾</span></span>';
            html += '</button>';

            // Body
            html += '<div class="cfg-accordion-body" id="cfg-acc-' + key + '">';

            if (isColor) {
                html += '<div class="cfg-color-grid">';
                group.forEach(opt => {
                    const active = state.options[key] === opt.id ? 'cfg-color-card-active' : '';
                    const tip = (meta.tips && meta.tips[opt.id]) || '';
                    const isRec = meta.recommended === opt.id;
                    html += '<button class="cfg-color-card ' + active + '" data-option-key="' + key + '" data-option-id="' + opt.id + '" title="' + tip + '">';
                    html += '<span class="cfg-color-tile" style="background:' + opt.hex + ';"></span>';
                    html += '<span class="cfg-color-name">' + opt.name + '</span>';
                    if (opt.priceDelta > 0) html += '<span class="cfg-price-tag">+$' + opt.priceDelta + '</span>';
                    if (isRec) html += '<span class="cfg-rec-badge">Popular</span>';
                    html += '</button>';
                });
                html += '</div>';
            } else {
                html += '<div class="cfg-option-cards">';
                group.forEach(opt => {
                    const active = state.options[key] === opt.id ? 'cfg-opt-card-active' : '';
                    const tip = (meta.tips && meta.tips[opt.id]) || '';
                    const isRec = meta.recommended === opt.id;
                    html += '<button class="cfg-opt-card ' + active + '" data-option-key="' + key + '" data-option-id="' + opt.id + '">';
                    html += '<div class="cfg-opt-card-top">';
                    html += '<span class="cfg-opt-card-name">' + opt.name + '</span>';
                    if (opt.priceDelta > 0) html += '<span class="cfg-price-tag">+$' + opt.priceDelta + '</span>';
                    else if (opt.priceDelta === 0) html += '<span class="cfg-price-tag cfg-price-free">Included</span>';
                    html += '</div>';
                    if (tip) html += '<span class="cfg-opt-card-tip">' + tip + '</span>';
                    if (isRec) html += '<span class="cfg-rec-badge">Most Popular</span>';
                    html += '</button>';
                });
                html += '</div>';
            }

            html += '</div>'; // body
            html += '</div>'; // accordion
        });

        container.innerHTML = html;
    }

    // Accordion toggle
    document.getElementById('cfg-options-container').addEventListener('click', (e) => {
        const toggle = e.target.closest('[data-toggle]');
        if (toggle) {
            const key = toggle.dataset.toggle;
            const body = document.getElementById('cfg-acc-' + key);
            if (body) body.classList.toggle('cfg-acc-closed');
            return;
        }

        const btn = e.target.closest('[data-option-key]');
        if (!btn) return;
        const key = btn.dataset.optionKey;
        const id = btn.dataset.optionId;
        state.options[key] = id;

        // Re-render everything (accordion states, progress, conditional fields)
        renderOptions();
        updatePriceBar();
        updateLivePreview();
    });

    // --- Live Preview ---
    function updateLivePreview() {
        if (!state.product) return;
        const opts = state.options;
        const p = state.product;
        const previewImg = document.getElementById('cfg-preview-img');
        const noFabric = document.getElementById('cfg-preview-no-fabric');
        const optsSummary = document.getElementById('cfg-preview-options');

        // Show catalog page image if fabric was selected from a catalog
        if (state.fabricReference && state.fabricCode && p.catalogSection) {
            // Extract page number from fabricReference: "CODE (Catalog, p.XX)"
            const pageMatch = state.fabricReference.match(/p\.(\d+)/);
            if (pageMatch) {
                const pageNum = parseInt(pageMatch[1]);
                const catalog = catalogs ? catalogs.find(c => c.id === p.catalogSection.catalogId) : null;

                if (catalog) {
                    const padded = catalog.pages >= 10 ? String(pageNum).padStart(2, '0') : String(pageNum);
                    const imgUrl = '/assets/catalogs/' + catalog.folder + '/page-' + padded + '.jpg';
                    previewImg.src = imgUrl;
                    previewImg.alt = 'Fabric ' + state.fabricCode + ' from catalog';
                    previewImg.style.display = 'block';
                    if (noFabric) noFabric.style.display = 'none';
                }
            }
        } else if (p.image) {
            previewImg.src = p.image;
            previewImg.alt = p.name;
            previewImg.style.display = 'block';
            if (noFabric) noFabric.style.display = 'none';
        }

        // Build options summary chips below image
        if (optsSummary) {
            const allLabels = {
                mount: 'Mount', valanceStyle: 'Valance', movement: 'Movement',
                chainColor: 'Chain', bottomBar: 'Bar', valanceColor: 'Valance Color',
                bottomRailColor: 'Rail Color', slatSize: 'Slat', cordless: 'Lift',
                fabric: 'Fabric', motorized: 'Motor', motorProtocol: 'Protocol',
                color: 'Color', foldStyle: 'Fold', lining: 'Lining', operation: 'Operation'
            };

            let html = '';

            // Fabric code chip
            if (state.fabricCode) {
                html += '<span class="cfg-opt-chip cfg-opt-chip-gold">🏷️ ' + state.fabricCode + '</span>';
            }

            // Option chips
            Object.keys(opts).forEach(key => {
                if (!p.options[key]) return;
                const sel = p.options[key].find(o => o.id === opts[key]);
                if (!sel) return;

                // Skip chainColor if not chain movement
                if (key === 'chainColor' && opts.movement !== 'chain') return;

                const label = allLabels[key] || key;

                // Color chips show a dot
                if (sel.hex) {
                    html += '<span class="cfg-opt-chip"><span class="cfg-opt-dot" style="background:' + sel.hex + ';"></span>' + label + ': ' + sel.name + '</span>';
                } else {
                    html += '<span class="cfg-opt-chip">' + label + ': ' + sel.name + '</span>';
                }
            });

            optsSummary.innerHTML = html;
        }
    }

    // Catalogs data for preview image lookup (hardcoded, matches configure.astro)
    var catalogs = [
        { id: "blinds", pages: 65, folder: "blinds-catalog" },
        { id: "smart-curtain", pages: 10, folder: "smart-curtain" },
        { id: "roman", pages: 6, folder: "roman-swatches" }
    ];

    document.getElementById('cfg-options-next').addEventListener('click', () => goToStep(4));

    // --- Step 4: Review ---
    function renderReview() {
        const card = document.getElementById('cfg-review-card');
        const p = state.product;
        const w = (state.widthWhole || 0) + state.widthFrac;
        const h = (state.heightWhole || 0) + state.heightFrac;
        const price = calculatePrice();
        const total = price * state.quantity;
        const today = new Date();
        const dateStr = today.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
        const orderNum = 'BS-' + today.getFullYear() + '-' + String(Math.floor(Math.random() * 9000) + 1000);

        let subtypeName = '';
        if (p.subtypes && state.subtypeId) {
            const st = p.subtypes.find(s => s.id === state.subtypeId);
            subtypeName = st ? st.name : '';
        }

        const selectedColor = p.options.color ? p.options.color.find(c => c.id === state.options.color) : null;

        const labels = {
            mount: 'Mount Type', slatSize: 'Slat Size', color: 'Color',
            cordless: 'Lift System', fabric: 'Fabric Type', motorized: 'Operation',
            motorProtocol: 'Motor Protocol', operation: 'Operation'
        };

        // Build specs rows
        let specsRows = '';
        Object.keys(state.options).forEach(key => {
            const optGroup = p.options[key];
            if (!optGroup) return;
            const selected = optGroup.find(o => o.id === state.options[key]);
            if (!selected) return;
            const label = labels[key] || key;
            let value = selected.name;
            let deltaStr = '';
            if (key !== 'color' && selected.priceDelta > 0) {
                deltaStr = '<span class="cfg-inv-delta">+$' + selected.priceDelta.toFixed(2) + '</span>';
            }
            if (key === 'color' && selectedColor) {
                value = '<span class="cfg-review-color" style="background:' + selectedColor.hex + ';border:1px solid #ccc;"></span> ' + selected.name;
            }
            specsRows += '<tr><td>' + label + '</td><td>' + value + '</td><td class="cfg-inv-right">' + deltaStr + '</td></tr>';
        });

        let html = '';

        // Invoice header (dark background so logo shows properly)
        html += '<div class="cfg-inv-header">';
        html += '<div class="cfg-inv-logo">';
        html += '<img src="/assets/images/main-logo-compressed.png" alt="Boutique Shutters" />';
        html += '</div>';
        html += '<div class="cfg-inv-meta">';
        html += '<span class="cfg-inv-label">Estimate</span>';
        html += '<span class="cfg-inv-num">' + orderNum + '</span>';
        html += '<span class="cfg-inv-date">' + dateStr + '</span>';
        html += '</div>';
        html += '</div>';

        // Product line item
        html += '<table class="cfg-inv-table">';
        html += '<thead><tr><th>Item</th><th>Details</th><th class="cfg-inv-right">Amount</th></tr></thead>';
        html += '<tbody>';
        html += '<tr class="cfg-inv-product-row">';
        html += '<td><strong>' + p.name + (subtypeName ? '<br><small>' + subtypeName + '</small>' : '') + '</strong></td>';
        html += '<td>' + w + '" W × ' + h + '" H &nbsp;·&nbsp; Qty: ' + state.quantity + '</td>';

        let basePrice = p.basePrice || 0;
        if (p.subtypes && state.subtypeId) {
            const st = p.subtypes.find(s => s.id === state.subtypeId);
            if (st) basePrice = st.basePrice;
        }
        if (p.checkoutEnabled) {
            html += '<td class="cfg-inv-right">$' + basePrice.toFixed(2) + '</td>';
        } else {
            html += '<td class="cfg-inv-right">—</td>';
        }
        html += '</tr>';
        html += '</tbody></table>';

        // Specifications
        html += '<div class="cfg-inv-section-label">Specifications</div>';
        html += '<table class="cfg-inv-table cfg-inv-specs">';
        html += '<tbody>' + specsRows + '</tbody>';
        html += '</table>';

        // Totals
        if (p.checkoutEnabled) {
            const oversizeNote = (w > 72 || h > 72) ? '<tr><td colspan="2">Oversize surcharge (15%)</td><td class="cfg-inv-right">Included</td></tr>' : '';
            html += '<div class="cfg-inv-totals">';
            html += '<table class="cfg-inv-table">';
            html += '<tbody>';
            var taxRate = 0.07; // 7% Georgia sales tax
            var taxAmount = total * taxRate;
            var grandTotal = total + taxAmount;

            html += '<tr><td colspan="2">Unit Price</td><td class="cfg-inv-right">$' + price.toFixed(2) + '</td></tr>';
            html += oversizeNote;
            html += '<tr><td colspan="2">Quantity</td><td class="cfg-inv-right">× ' + state.quantity + '</td></tr>';
            html += '<tr class="cfg-inv-subtotal"><td colspan="2">Subtotal</td><td class="cfg-inv-right">$' + total.toFixed(2) + '</td></tr>';
            html += '<tr><td colspan="2">Shipping</td><td class="cfg-inv-right" style="color:#2ecc71;font-weight:700;">FREE</td></tr>';
            html += '<tr><td colspan="2">Est. Tax (GA 7%)</td><td class="cfg-inv-right">$' + taxAmount.toFixed(2) + '</td></tr>';
            html += '</tbody></table>';
            html += '<div class="cfg-inv-grand-total">';
            html += '<span>Estimated Total</span>';
            html += '<span>$' + grandTotal.toFixed(2) + '</span>';
            html += '</div>';
            html += '<div class="cfg-inv-financing">As low as <strong>$' + Math.round(grandTotal / 12) + '/mo</strong> with Wisetack or Klarna financing</div>';
            html += '</div>';
        } else {
            html += '<div class="cfg-inv-totals">';
            html += '<div class="cfg-inv-grand-total">';
            html += '<span>Pricing</span>';
            html += '<span>Custom Quote Required</span>';
            html += '</div>';
            html += '</div>';
        }

        // Footer note
        html += '<div class="cfg-inv-footer">';
        html += '<p>This is an estimate only. Final pricing may vary based on installation requirements. Free shipping on all orders. Professional installation available.</p>';
        html += '<p>Questions? Call <a href="tel:404-966-7419">404-966-7419</a> or email <a href="mailto:sales@boutiqueshutters.com">sales@boutiqueshutters.com</a></p>';
        html += '</div>';

        card.innerHTML = html;

        const nextBtn = document.getElementById('cfg-review-next');
        nextBtn.textContent = p.checkoutEnabled ? 'Add to Cart →' : 'Request Custom Quote →';
    }

    document.getElementById('cfg-review-next').addEventListener('click', () => {
        if (state.product.checkoutEnabled) {
            goToStep(5);
        } else {
            // Open lead form with pre-filled data
            if (typeof window.openLeadModal === 'function') {
                const productSelect = document.getElementById('lead-product');
                if (productSelect) productSelect.value = 'Exterior Shades';
                const msgField = document.getElementById('lead-message');
                if (msgField) {
                    const w = (state.widthWhole || 0) + state.widthFrac;
                    const h = (state.heightWhole || 0) + state.heightFrac;
                    msgField.value = 'Product: ' + state.product.name + '\nSize: ' + w + '" × ' + h + '"\nQuantity: ' + state.quantity + '\nOptions: ' + Object.entries(state.options).map(([k,v]) => k + ': ' + v).join(', ');
                }
                window.openLeadModal();
            }
        }
    });

    // --- Step 5: Cart ---
    function renderCart() {
        const area = document.getElementById('cfg-cart-area');
        const p = state.product;
        const price = calculatePrice();
        const total = price * state.quantity;
        const w = (state.widthWhole || 0) + state.widthFrac;
        const h = (state.heightWhole || 0) + state.heightFrac;

        let subtypeName = '';
        if (p.subtypes && state.subtypeId) {
            const st = p.subtypes.find(s => s.id === state.subtypeId);
            subtypeName = st ? ' — ' + st.name : '';
        }

        const itemId = [p.id, state.subtypeId || '', w, h, Object.values(state.options).join('-')].filter(Boolean).join('-');
        const itemName = p.name + subtypeName;

        // Build custom fields HTML
        let customFields = '';
        let customIdx = 1;
        customFields += ' data-item-custom' + customIdx + '-name="Size" data-item-custom' + customIdx + '-value="' + w + '&quot; × ' + h + '&quot;"';
        customIdx++;
        customFields += ' data-item-custom' + customIdx + '-name="Quantity" data-item-custom' + customIdx + '-value="' + state.quantity + '"';
        customIdx++;

        const labels = { mount: 'Mount', slatSize: 'Slat Size', color: 'Color', cordless: 'Lift System', fabric: 'Fabric', motorized: 'Operation', motorProtocol: 'Motor' };
        Object.keys(state.options).forEach(key => {
            const optGroup = p.options[key];
            if (!optGroup) return;
            const selected = optGroup.find(o => o.id === state.options[key]);
            if (!selected) return;
            customFields += ' data-item-custom' + customIdx + '-name="' + (labels[key] || key) + '" data-item-custom' + customIdx + '-value="' + selected.name + '"';
            customIdx++;
        });

        // Add fabric reference if selected
        if (state.fabricReference) {
            customFields += ' data-item-custom' + customIdx + '-name="Fabric Reference" data-item-custom' + customIdx + '-value="' + state.fabricReference + '"';
            customIdx++;
        }

        const cartTax = total * 0.07;
        const cartGrand = total + cartTax;

        area.innerHTML = `
            <div class="cfg-cart-icon">✓</div>
            <h2 class="cfg-title">Ready to Add to Cart</h2>
            <p class="cfg-subtitle">${itemName} — ${w}" × ${h}" — Qty: ${state.quantity}</p>
            <div class="cfg-cart-breakdown">
                <div class="cfg-cart-line"><span>Subtotal</span><span>$${total.toFixed(2)}</span></div>
                <div class="cfg-cart-line"><span>Shipping</span><span style="color:#2ecc71;">FREE</span></div>
                <div class="cfg-cart-line"><span>Est. Tax (GA 7%)</span><span>$${cartTax.toFixed(2)}</span></div>
                <div class="cfg-cart-line cfg-cart-line-total"><span>Estimated Total</span><span>$${cartGrand.toFixed(2)}</span></div>
            </div>
            <button class="snipcart-add-item cfg-add-to-cart"
                data-item-id="${itemId}"
                data-item-name="${itemName}"
                data-item-price="${price.toFixed(2)}"
                data-item-quantity="${state.quantity}"
                data-item-url="/configure"
                data-item-description="${w}&quot; × ${h}&quot; custom ${p.name.toLowerCase()}"
                ${customFields}
            >
                Add to Cart — $${cartGrand.toFixed(2)}
            </button>
            <div class="cfg-cart-actions">
                <button class="cfg-btn-continue" onclick="document.querySelectorAll('.cfg-product-card')[0].click()">← Configure Another Window</button>
                <a href="/cart" class="cfg-btn-checkout" style="text-decoration:none;">View Cart & Checkout →</a>
            </div>
            <div class="cfg-cart-trust">
                <span class="cfg-trust-badge">🚚 Free Shipping</span>
                <span class="cfg-trust-badge">✓ Satisfaction Guaranteed</span>
                <span class="cfg-trust-badge">🔒 Secure Checkout</span>
                <span class="cfg-trust-badge">💳 Financing Available</span>
            </div>
            <div class="cfg-cart-financing">
                As low as <strong>$${Math.round(cartGrand / 12)}/mo</strong> with
                <img src="/assets/images/partners/wisetack-logo-dark.svg" alt="Wisetack" height="14" style="vertical-align:middle;margin:0 4px;" />
                or
                <img src="/assets/images/partners/klarna-logo-dark.svg" alt="Klarna" height="14" style="vertical-align:middle;margin:0 4px;" />
            </div>
        `;
    }

    // --- Price Calculation ---
    function calculatePrice() {
        if (!state.product) return 0;
        if (!state.product.checkoutEnabled) return 0;

        let base = state.product.basePrice || 0;
        if (state.product.subtypes && state.subtypeId) {
            const st = state.product.subtypes.find(s => s.id === state.subtypeId);
            if (st) base = st.basePrice;
        }

        let delta = 0;
        if (state.product.options) {
            Object.keys(state.options).forEach(key => {
                const group = state.product.options[key];
                if (!group) return;
                const selected = group.find(o => o.id === state.options[key]);
                if (selected) delta += selected.priceDelta || 0;
            });
        }

        let unitPrice = base + delta;

        // Oversize surcharge
        const w = (state.widthWhole || 0) + state.widthFrac;
        const h = (state.heightWhole || 0) + state.heightFrac;
        if (w > 72 || h > 72) unitPrice = Math.round(unitPrice * 1.15);

        return unitPrice;
    }

    function updatePriceBar() {
        if (!state.product) return;
        const price = calculatePrice();
        const total = price * state.quantity;
        barProduct.textContent = state.product.name;
        if (state.product.checkoutEnabled) {
            barPrice.textContent = total > 0 ? '$' + total.toFixed(2) : 'From $' + (state.product.subtypes ? state.product.subtypes[0].basePrice : state.product.basePrice);
        } else {
            barPrice.textContent = 'Custom Quote';
        }
    }

    // Session storage persistence
    function saveState() {
        try { sessionStorage.setItem('cfgState', JSON.stringify(state)); } catch(e) {}
    }

    // Initialize
    goToStep(1);
})();
</script>

