        }

        .cfg-step-indicator.cfg-active .cfg-step-label {
            color: var(--secondary);
        }

        .cfg-step-indicator.cfg-done .cfg-step-num {
            background: #2ecc71;
            color: white;
        }

        .cfg-step-indicator.cfg-done .cfg-step-label {
            color: #2ecc71;
        }

        .cfg-step-line {
            flex: 1;
            height: 2px;
            background: #e0e0e0;
            margin: 0 (4/16rem);
            margin-bottom: (18/16rem);
            max-width: (60/16rem);
        }

        /* Panel */
        .cfg-panel {
            max-width: (900/16rem);
            margin: 0 auto;
        }

        .cfg-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.5rem, 3vw, 2rem);
            font-weight: 700;
            margin: 0 0 (8/16rem) 0;
            text-align: center;
        }

        .cfg-subtitle {
            font-size: (16/16rem);
            color: #888;
            text-align: center;
            margin: 0 0 clamp(1.5rem, 3vw, 2rem) 0;
        }

        /* Step 1: Product Cards */
        .cfg-product-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: (16/16rem);
        }

        .cfg-product-card {
            background: white;
            border: 2px solid #e0e0e0;
            cursor: pointer;
            overflow: hidden;
            transition: border-color 0.3s, box-shadow 0.3s;
            display: flex;
            flex-direction: column;
            text-align: left;
            font-family: inherit;
            padding: 0;

            &:hover {
                border-color: var(--secondary);
                box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            }

            img {
                width: 100%;
                height: (200/16rem);
                object-fit: cover;
            }
        }

        .cfg-product-info {
            padding: (16/16rem);

            h3 {
                font-family: 'Playfair Display', serif;
                font-size: (18/16rem);
                font-weight: 700;
                margin: 0 0 (4/16rem) 0;
            }

            p {
                font-size: (14/16rem);
                color: #888;
                margin: 0 0 (8/16rem) 0;
            }
        }

        .cfg-price-badge {
            display: inline-block;
            background: var(--secondary);
            color: #000;
            font-weight: 700;
            font-size: (13/16rem);
            padding: (4/16rem) (12/16rem);

            &.cfg-contact {
                background: #1a1a1a;
                color: var(--secondary);
            }
        }

        /* Step 2: Size */
        .cfg-label {
            display: block;
            font-weight: 700;
            font-size: (14/16rem);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: (8/16rem);
            color: #333;
        }

        .cfg-size-form {
            display: flex;
            flex-direction: column;
            gap: (20/16rem);
            margin-bottom: (24/16rem);
        }

        .cfg-size-group {
            flex: 1;
        }

        .cfg-size-inputs {
            display: flex;
            gap: (8/16rem);
            flex-wrap: wrap;
        }

        .cfg-input, .cfg-select {
            font-family: inherit;
            font-size: (16/16rem);
            padding: (10/16rem) (12/16rem);
            border: 2px solid #e0e0e0;
            background: white;
            transition: border-color 0.3s;
            box-sizing: border-box;

            &:focus {
                outline: none;
                border-color: var(--secondary);
            }
        }

        .cfg-input {
            flex: 1;
            min-width: (80/16rem);
        }

        .cfg-select {
            width: (70/16rem);
            flex-shrink: 0;
        }

        .cfg-size-preview {
            text-align: center;
            margin-bottom: (24/16rem);
        }

        .cfg-preview-box {
            width: (120/16rem);
            height: (120/16rem);
            border: 2px solid var(--secondary);
            margin: 0 auto (8/16rem);
            transition: all 0.3s;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 8px,
                rgba(0,0,0,0.05) 8px,
                rgba(0,0,0,0.05) 10px
            );
        }

        .cfg-preview-dims {
            font-size: (14/16rem);
            font-weight: 600;
            color: #666;
        }

        .cfg-quantity-row {
            margin-bottom: (24/16rem);
        }

        .cfg-qty-control {
            display: flex;
            align-items: center;
            gap: 0;
            width: fit-content;
        }

        .cfg-qty-btn {
            width: (40/16rem);
            height: (40/16rem);
            border: 2px solid #e0e0e0;
            background: white;
            font-size: (18/16rem);
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
            transition: background 0.3s;

            &:hover { background: #f0f0f0; }
        }

        .cfg-qty-input {
            width: (60/16rem);
            height: (40/16rem);
            border: 2px solid #e0e0e0;
            border-left: none;
            border-right: none;
            text-align: center;
            font-size: (16/16rem);
            font-family: inherit;
            font-weight: 700;
        }

        /* Subtype pills & option pills */
        .cfg-pill-group {
            display: flex;
            flex-wrap: wrap;
            gap: (8/16rem);
        }

        .cfg-pill {
            font-family: inherit;
            font-size: (14/16rem);
            font-weight: 600;
            padding: (8/16rem) (16/16rem);
            border: 2px solid #e0e0e0;
            background: white;
            cursor: pointer;
            transition: all 0.3s;

            &:hover { border-color: var(--secondary); }

            &.cfg-pill-active {
                background: var(--secondary);
                border-color: var(--secondary);
                color: #000;
            }
        }

        /* Color swatches */
        .cfg-color-swatches {
            display: flex;
            flex-wrap: wrap;
            gap: (8/16rem);
        }

        .cfg-swatch {
            width: (40/16rem);
            height: (40/16rem);
            border-radius: 50%;
            border: 3px solid #e0e0e0;
            cursor: pointer;
            position: relative;
            transition: all 0.3s;
            padding: 0;

            &:hover {
                border-color: var(--secondary);
                transform: scale(1.1);
            }

            &.cfg-swatch-active {
                border-color: var(--secondary);
                box-shadow: 0 0 0 3px var(--secondary);
            }
        }

        .cfg-swatch-label {
            position: absolute;
            bottom: -(22/16rem);
            left: 50%;
            transform: translateX(-50%);
            font-size: (10/16rem);
            white-space: nowrap;
            color: #666;
            opacity: 0;
            transition: opacity 0.2s;
        }

        .cfg-swatch:hover .cfg-swatch-label,
        .cfg-swatch.cfg-swatch-active .cfg-swatch-label {
            opacity: 1;
        }

        /* Options layout with live preview */
        .cfg-options-layout {
            display: flex;
            flex-direction: column;
            gap: clamp(1.5rem, 3vw, 2rem);
        }

        .cfg-preview-panel {
            width: 100%;
            display: flex;
            justify-content: center;
        }

        .cfg-preview-window {
            width: 100%;
        }

        .cfg-preview-img-wrap {
            position: relative;
            background: #f7f7f7;
            border: 1px solid #e0e0e0;
            overflow: hidden;
            min-height: (150/16rem);
        }

        .cfg-preview-catalog-img {
            width: 100%;
            height: auto;
            display: none;
            max-height: (400/16rem);
            object-fit: contain;
            background: white;
        }

        .cfg-preview-no-fabric {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: (32/16rem) (16/16rem);
            color: #999;

            span { font-size: (32/16rem); margin-bottom: (8/16rem); }
            p { font-size: (13/16rem); margin: 0; text-align: center; }
        }

        .cfg-preview-options {
            display: flex;
            flex-wrap: wrap;
            gap: (4/16rem);
            margin-top: (8/16rem);
        }

        .cfg-opt-chip {
            display: inline-flex;
            align-items: center;
            gap: (4/16rem);
            font-size: (11/16rem);
            font-weight: 600;
            padding: (3/16rem) (8/16rem);
            background: #f0f0f0;
            color: #555;
            border-radius: (3/16rem);

            &.cfg-opt-chip-gold {
                background: var(--secondary);
                color: #000;
                font-weight: 700;
            }
        }

        .cfg-opt-dot {
            width: (10/16rem);
            height: (10/16rem);
            border-radius: 50%;
            border: 1px solid #ccc;
            flex-shrink: 0;
        }

        .cfg-options-form {
            flex: 1;
        }

        /* Fabric step */
        .cfg-fabric-status {
            margin-bottom: (24/16rem);
        }

        .cfg-fabric-empty {
            text-align: center;
            padding: (32/16rem) (16/16rem);
            background: #f7f7f7;
            border: 2px dashed #ccc;

            .cfg-fabric-icon {
                font-size: (40/16rem);
                display: block;
                margin-bottom: (8/16rem);
            }

            p {
                font-size: (15/16rem);
                color: #888;
                margin: 0;
            }
        }

        .cfg-fabric-selected {
            display: flex;
            align-items: center;
            gap: (16/16rem);
            padding: (16/16rem) (20/16rem);
            background: #f0fdf4;
            border: 2px solid #2ecc71;
        }

        .cfg-fabric-check {
            font-size: (24/16rem);
            color: #2ecc71;
            font-weight: 700;
        }

        .cfg-fabric-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: (2/16rem);
        }

        .cfg-fabric-code-display {
            font-size: (18/16rem);
            font-weight: 900;
            color: #1a1a1a;
        }

        .cfg-fabric-ref {
            font-size: (13/16rem);
            color: #888;
        }

        .cfg-fabric-change {
            font-family: inherit;
            font-size: (13/16rem);
            font-weight: 600;
            padding: (6/16rem) (14/16rem);
            border: 1px solid #ccc;
            background: white;
            cursor: pointer;
            transition: all 0.2s;

            &:hover { border-color: var(--secondary); color: var(--secondary); }
        }

        .cfg-btn-disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        /* Options progress */
        .cfg-opts-progress {
            margin-bottom: (16/16rem);
        }

        .cfg-opts-progress-text {
            font-size: (12/16rem);
            font-weight: 600;
            color: #888;
            display: block;
            margin-bottom: (4/16rem);
        }

        .cfg-opts-progress-bar {
            height: (4/16rem);
            background: #e0e0e0;
            border-radius: (2/16rem);
            overflow: hidden;
        }

        .cfg-opts-progress-fill {
            height: 100%;
            background: var(--secondary);
            border-radius: (2/16rem);
            transition: width 0.3s;
        }

        .cfg-opts-total {
            font-size: (14/16rem);
            color: #666;
            margin-bottom: (16/16rem);
            padding: (8/16rem) (12/16rem);
            background: #f7f7f7;
            border-left: 3px solid var(--secondary);

            strong { color: var(--secondary); font-size: (18/16rem); }
        }

        /* Accordion */
        .cfg-accordion {
            border: 1px solid #e0e0e0;
            margin-bottom: (8/16rem);
            transition: border-color 0.2s;

            &.cfg-accordion-done {
                border-color: #2ecc71;
                border-left: 3px solid #2ecc71;
            }
        }

        .cfg-accordion-header {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: (12/16rem) (16/16rem);
            background: white;
            border: none;
            cursor: pointer;
            font-family: inherit;
            font-size: (14/16rem);
            font-weight: 600;
            color: #333;
            transition: background 0.2s;

            &:hover { background: #fafafa; }

            em { color: #ccc; font-style: normal; }
        }

        .cfg-accordion-value {
            font-size: (13/16rem);
            color: #888;
            display: flex;
            align-items: center;
            gap: (4/16rem);
        }

        .cfg-accordion-done .cfg-accordion-value {
            color: #2ecc71;
            font-weight: 700;
        }

        .cfg-accordion-arrow {
            font-size: (10/16rem);
            transition: transform 0.2s;
        }

        .cfg-accordion-body {
            overflow: hidden;
            transition: max-height 0.3s, padding 0.3s;
            padding: (12/16rem) (16/16rem) (16/16rem);
            max-height: (800/16rem);

            &.cfg-acc-closed {
                max-height: 0;
                padding: 0 (16/16rem);
            }
        }

        /* Option cards */
        .cfg-option-cards {
            display: flex;
            flex-direction: column;
            gap: (6/16rem);
        }

        .cfg-opt-card {
            display: flex;
            flex-direction: column;
            gap: (2/16rem);
            padding: (10/16rem) (14/16rem);
            border: 2px solid #e8e8e8;
            background: white;
            cursor: pointer;
            font-family: inherit;
            text-align: left;
            transition: all 0.2s;
            position: relative;

            &:hover { border-color: var(--secondary); background: #fffdf5; }

            &.cfg-opt-card-active {
                border-color: var(--secondary);
                background: #fffbeb;
                box-shadow: 0 0 0 1px var(--secondary);
            }
        }

        .cfg-opt-card-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .cfg-opt-card-name {
            font-size: (14/16rem);
            font-weight: 700;
            color: #333;
        }

        .cfg-opt-card-tip {
            font-size: (12/16rem);
            color: #888;
            line-height: 1.3;
        }

        .cfg-price-tag {
            font-size: (11/16rem);
            font-weight: 700;
            color: var(--secondary);
            background: #1a1a1a;
            padding: (2/16rem) (8/16rem);
            border-radius: (2/16rem);

            &.cfg-price-free {
                color: #2ecc71;
                background: #f0fdf4;
            }
        }

        .cfg-rec-badge {
            display: inline-block;
            font-size: (10/16rem);
            font-weight: 700;
            color: white;
            background: #2ecc71;
            padding: (2/16rem) (6/16rem);
            border-radius: (2/16rem);
            text-transform: uppercase;
            letter-spacing: 0.03em;
            margin-top: (2/16rem);
        }

        /* Color grid */
        .cfg-color-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: (6/16rem);
        }

        .cfg-color-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: (4/16rem);
            padding: (8/16rem);
            border: 2px solid #e8e8e8;
            background: white;
            cursor: pointer;
            font-family: inherit;
            transition: all 0.2s;

            &:hover { border-color: var(--secondary); }

            &.cfg-color-card-active {
                border-color: var(--secondary);
                box-shadow: 0 0 0 1px var(--secondary);
            }
        }

        .cfg-color-tile {
            width: (36/16rem);
            height: (36/16rem);
            border-radius: 50%;
            border: 2px solid #ddd;
        }

        .cfg-color-name {
            font-size: (11/16rem);
            font-weight: 600;
            color: #555;
        }

        /* Keep old option-group for backwards compat */
        .cfg-option-group {
            margin-bottom: (24/16rem);
        }

        /* Navigation buttons */
        .cfg-nav-buttons {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: clamp(1.5rem, 3vw, 2rem);
            padding-top: (16/16rem);
            border-top: 1px solid #e0e0e0;
        }

        .cfg-btn-back {
            font-family: inherit;
            font-size: (14/16rem);
            font-weight: 600;
            padding: (10/16rem) (20/16rem);
            border: 2px solid #e0e0e0;
            background: white;
            cursor: pointer;
            transition: all 0.3s;

            &:hover { border-color: #999; }
        }

        .cfg-btn-next {
            font-family: inherit;
            font-size: (14/16rem);
            font-weight: 700;
            padding: (12/16rem) (24/16rem);
            border: none;
            background: var(--secondary);
            color: #000;
            cursor: pointer;
            transition: all 0.3s;

            &:hover { background: var(--csButtonHoverColor); }
        }

        /* Step 4: Invoice-style Review */
        .cfg-review-card {
            background: white;
            border: 1px solid #e0e0e0;
            padding: clamp(1.25rem, 3vw, 2rem);
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }

        .cfg-inv-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: (12/16rem);
            padding: (16/16rem) (20/16rem);
            margin-bottom: (20/16rem);
            background: #1a1a1a;
        }

        .cfg-inv-logo {
            display: flex;
            align-items: center;

            img { height: (32/16rem); width: auto; max-width: (180/16rem); }
        }

        .cfg-inv-meta {
            text-align: right;
            display: flex;
            flex-direction: column;
            gap: (2/16rem);
        }

        .cfg-inv-label {
            font-size: (20/16rem);
            font-weight: 900;
            font-family: 'Playfair Display', serif;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--secondary);
        }

        .cfg-inv-num {
            font-size: (11/16rem);
            font-weight: 600;
            color: #888;
            font-family: monospace;
        }

        .cfg-inv-date {
            font-size: (11/16rem);
            color: #666;
        }

        .cfg-inv-table {
            width: 100%;
            border-collapse: collapse;
            font-size: (13/16rem);
            table-layout: fixed;
            word-wrap: break-word;
            overflow-wrap: break-word;

            th {
                text-align: left;
                font-size: (11/16rem);
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                color: #888;
                padding: (8/16rem) 0;
                border-bottom: 1px solid #e0e0e0;
            }

            td {
                padding: (8/16rem) 0;
                border-bottom: 1px solid #f0f0f0;
                vertical-align: top;
                color: #333;
            }

            strong { color: #1a1a1a; }
            small { color: #888; font-weight: 400; }
        }

        .cfg-inv-right { text-align: right !important; }

        .cfg-inv-delta {
            font-size: (12/16rem);
            color: #888;
        }

        .cfg-inv-product-row td {
            padding: (12/16rem) 0;
            font-size: (15/16rem);
        }

        .cfg-inv-section-label {
            font-size: (11/16rem);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #888;
            margin-top: (20/16rem);
            margin-bottom: (4/16rem);
        }

        .cfg-inv-specs td {
            font-size: (13/16rem);
            padding: (6/16rem) 0;
        }

        .cfg-review-color {
            display: inline-block;
            width: (14/16rem);
            height: (14/16rem);
            border-radius: 50%;
            vertical-align: middle;
            margin-right: (4/16rem);
        }

        .cfg-inv-totals {
            margin-top: (20/16rem);
            padding-top: (12/16rem);
            border-top: 2px solid #1a1a1a;
        }

        .cfg-inv-totals .cfg-inv-table td {
            padding: (6/16rem) 0;
            font-size: (14/16rem);
            border-bottom: none;
        }

        .cfg-inv-subtotal td {
            padding-top: (10/16rem) !important;
            border-top: 1px solid #e0e0e0 !important;
            font-weight: 600;
        }

        .cfg-inv-grand-total {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: (4/16rem);
            margin-top: (8/16rem);
            background: #1a1a1a;
            padding: (12/16rem) (16/16rem);

            span:first-child {
                font-size: (14/16rem);
                font-weight: 700;
                color: white;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }

            span:last-child {
                font-size: clamp(1.125rem, 3vw, 1.5rem);
                font-weight: 900;
                color: var(--secondary);
            }
        }

        .cfg-inv-financing {
            text-align: center;
            font-size: (13/16rem);
            color: #888;
            margin-top: (12/16rem);
            padding: (8/16rem);
            background: #f7f7f7;

            strong { color: var(--secondary); }
        }

        .cfg-inv-footer {
            margin-top: (20/16rem);
            padding-top: (12/16rem);
            border-top: 1px solid #e0e0e0;

            p {
                font-size: (12/16rem);
                color: #aaa;
                margin: 0 0 (4/16rem) 0;
                line-height: 1.5;
            }

            a {
                color: var(--secondary);
                text-decoration: none;
                font-weight: 600;

                &:hover { text-decoration: underline; }
            }
        }

        /* Step 5: Cart */
        .cfg-cart-success {
            text-align: center;
            padding: clamp(2rem, 5vw, 4rem) 0;
        }

        .cfg-cart-icon {
            width: (60/16rem);
            height: (60/16rem);
            background: #2ecc71;
            color: white;
            font-size: (28/16rem);
            font-weight: 700;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto (16/16rem);
        }

        .cfg-cart-total {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 900;
            color: var(--secondary);
            margin: (8/16rem) 0 (24/16rem);
        }

        .cfg-add-to-cart {
            font-family: inherit;
            font-size: (16/16rem);
            font-weight: 700;
            padding: (14/16rem) (32/16rem);
            border: none;
            background: var(--secondary);
            color: #000;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-block;

            &:hover { background: var(--csButtonHoverColor); }
        }

        .cfg-cart-actions {
            display: flex;
            gap: (10/16rem);
            justify-content: center;
            margin-top: (16/16rem);
            flex-wrap: wrap;
        }

        .cfg-btn-checkout {
            font-family: inherit;
            font-size: (14/16rem);
            font-weight: 700;
            padding: (12/16rem) (24/16rem);
            border: 2px solid #1a1a1a;
            background: #1a1a1a;
            color: white;
            cursor: pointer;
            transition: all 0.3s;

            &:hover {
                background: #333;
            }
        }

        .cfg-cart-breakdown {
            max-width: (320/16rem);
            margin: 0 auto (20/16rem);
        }

        .cfg-cart-line {
            display: flex;
            justify-content: space-between;
            padding: (6/16rem) 0;
            font-size: (14/16rem);
            color: #666;
            border-bottom: 1px solid #f0f0f0;

            &.cfg-cart-line-total {
                border-bottom: none;
                border-top: 2px solid #1a1a1a;
                padding-top: (10/16rem);
                margin-top: (4/16rem);
                font-size: (18/16rem);
                font-weight: 900;
                color: #1a1a1a;

                span:last-child { color: var(--secondary); }
            }
        }

        .cfg-cart-trust {
            display: flex;
            justify-content: center;
            gap: (8/16rem);
            margin-top: (20/16rem);
            flex-wrap: wrap;
        }

        .cfg-trust-badge {
            font-size: (12/16rem);
            font-weight: 600;
            color: #2ecc71;
            background: #f0fdf4;
            padding: (4/16rem) (10/16rem);
            border-radius: (3/16rem);
        }

        .cfg-cart-financing {
            text-align: center;
            font-size: (13/16rem);
            color: #888;
            margin-top: (12/16rem);

            strong { color: var(--secondary); }
        }

        .cfg-btn-continue {
            font-family: inherit;
            font-size: (14/16rem);
            font-weight: 600;
            padding: (12/16rem) (24/16rem);
            border: 2px solid #e0e0e0;
            background: white;
            cursor: pointer;

            &:hover { border-color: var(--secondary); color: var(--secondary); }
        }

        /* Sticky Price Bar */
        .cfg-price-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #1a1a1a;
            z-index: 999;
            padding: (12/16rem) (16/16rem);
        }

        .cfg-price-bar-inner {
            max-width: (1280/16rem);
            margin: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .cfg-price-bar-label {
            color: #e0e0e0;
            font-weight: 600;
            font-size: (13/16rem);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            min-width: 0;
            flex: 1;
        }

        .cfg-price-bar-total {
            color: var(--secondary);
            font-weight: 900;
            font-size: (20/16rem);
        }
    }
}

/* Tablet */
@media only screen and (min-width: 48rem) {
    #configurator {
        .cfg-step-label {
            display: block;
            font-size: (11/16rem);
            letter-spacing: 0.05em;
        }

        .cfg-product-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .cfg-size-form {
            flex-direction: row;
        }

