<style lang="less">
/*-- -------------------------- -->
<---          Footer            -->
<--- -------------------------- -*/

/* Mobile - 360px */
@media only screen and (min-width: 0rem) {
    #footer-1241 {
        padding: var(--sectionPadding);
        box-sizing: border-box;

        .cs-container {
            width: 100%;
            max-width: (1280/16rem);
            margin: auto;
            display: flex;
            flex-wrap: wrap;
            align-items: flex-start;
            /* 40px - 64px */
            gap: clamp(2.5rem, 6vw, 4rem);
        }

        .cs-top {
            width: 100%;
            /* makes the children behave like the parent doesnt exist. They now act as children of the next parent up, in this case the cs-container. That way we can use felxbox to arrange them with the rest of the footer elements */
            display: contents;
        }

        .cs-logo-group {
            text-align: left;
            max-width: (434/16rem);
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            /* 20px - 24px */
            gap: clamp(1.25rem, 3vw, 1.5rem);
        }

        .cs-logo {
            width: (200/16rem);
            height: auto;

            img {
                width: 100%;
                height: auto;
            }
        }

        .cs-logo-text {
            /* 14px - 16px */
            font-size: clamp(0.875rem, 1.5vw, 1rem);
            line-height: 1.5em;
            text-align: inherit;
            margin: 0;
            color: var(--bodyTextColor);
            opacity: 0.8;
        }

        .cs-social {
            border: 1px solid #1a1a1a;
            display: flex;
            justify-content: center;
            align-items: stretch;
        }

        .cs-social-link {
            width: (60/16rem);
            height: (60/16rem);
            border-right: 1px solid #1a1a1a;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: background-color 0.3s;

            &:last-of-type {
                border: none;
            }

            &:hover {
                background-color: var(--primary);
            }

            svg {
                width: (16/16rem);
                height: auto;

                path {
                    transition: fill 0.3s;
                }
            }
        }

        .cs-contact-group,
        .cs-gallery-group {
            text-align: left;
            width: auto;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: (20/16rem);
        }

        .cs-header {
            font-size: (20/16rem);
            line-height: 1.2em;
            font-weight: 700;
            text-align: inherit;
            color: var(--headerColor);
        }

        .cs-contact-info {
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            /* 8px - 12px */
            gap: clamp(0.5rem, 1.5vw, 0.75rem);
        }

        .cs-contact-link {
            /* 14px - 16px */
            font-size: clamp(0.875rem, 1.5vw, 1rem);
            line-height: 1.5em;
            text-align: inherit;
            text-decoration: none;
            margin: 0;
            color: var(--bodyTextColor);
            opacity: 0.8;
            display: flex;
            justify-content: flex-start;
            align-items: center;
            gap: (8/16rem);
            transition: color 0.3s;

            &:hover {
                color: var(--primary);
            }
        }

        .cs-gallery {
            width: 100%;
            max-width: (350/16rem);
            display: grid;
            align-items: center;
            gap: (8/16rem);
            grid-template-columns: repeat(auto-fit, minmax(4.75rem, 1fr));
            grid-template-rows: repeat(auto-fit, minmax(4.75rem, 1fr));
        }

        .cs-picture {
            width: 100%;
            height: 100%;
            aspect-ratio: 1;
            display: block;
            grid-column: span 1;
            position: relative;

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                position: absolute;
                top: 0;
                left: 0;
            }
        }

        .cs-bottom {
            width: 100%;
        }

        .cs-ul {
            margin: 0;
            padding: 0;
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            /* 24px - 40px */
            gap: clamp(1.5rem, 4vw, 2.5rem);
        }

        .cs-li {
            list-style: none;
            /* 14px - 16px */
            font-size: clamp(0.875rem, 1.5vw, 1rem);
            line-height: 1.5em;
            margin: 0;
            opacity: 0.8;
        }

        .cs-li-link {
            text-decoration: none;
            color: var(--bodyTextColor);
            transition: color 0.3s;

            &:hover {
                color: var(--primary);
            }
        }

        .cs-credit {
            /* 14px - 16px */
            font-size: clamp(0.875rem, 1.5vw, 1rem);
            line-height: 1.5em;
            text-align: center;
            margin: 0;
            /* 16px - 40px */
            margin-top: clamp(1rem, 4vw, 2.5rem);
            /* 16px - 40px */
            padding-top: clamp(1rem, 4vw, 2.5rem);
            border-top: 1px solid rgba(78, 75, 102, 0.3);
            color: var(--bodyTextColor);
            opacity: 0.8;
            display: block;
        }

        .cs-credit-link {
            font-size: inherit;
            line-height: inherit;
            text-decoration: none;
            color: inherit;
            transition: color 0.3s;

            &:hover {
                color: var(--primary);
            }
        }
    }
}

/* Tablet - 768px */
@media only screen and (min-width: 48rem) {
    #footer-1241 {
        .cs-logo-group {
            width: 33.5%;
        }

        .cs-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: (48/16rem);
        }
        .cs-gallery-group {
            width: 27%;
        }

        .cs-gallery {
            grid-template-columns: repeat(4, 1fr);
            grid-template-rows: 1fr;
        }
    }
}

/* Dark Mode */
@media only screen and (min-width: 0rem) {
    body.dark-mode {
        #footer-1241 {
            .cs-logo {
                /* turns logo white */
                filter: grayscale(1) brightness(1000%);
            }

            .cs-logo-text,
            .cs-header,
            .cs-li-link,
            .cs-li-link,
            .cs-credit-link,
            .cs-contact-link,
            .cs-credit {
                color: var(--bodyTextColorWhite);
            }

            .cs-contact-link,
            .cs-li-link,
            .cs-credit-link {
                &:hover {
                    color: var(--primary);
                }
            }

            .cs-social {
                border-color: var(--bodyTextColorWhite);
            }

            .cs-social-link {
                border-color: var(--bodyTextColorWhite);
                svg {
                    path {
                        fill: var(--bodyTextColorWhite);
                    }
                }
            }

            .cs-credit {
                border-color: rgba(255, 255, 255, 0.2);
            }
        }
    }
}                        
</style>