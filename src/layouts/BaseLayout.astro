---
import client from "@data/client.json";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LeadFormModal from "@components/LeadFormModal.astro";
import CartEnhancements from "@components/CartEnhancements.astro";
import "@styles/root.less";
const { description, title } = Astro.props;
---
<html lang="en">
        <head>

            <!-- Google tag (gtag.js) -->
            <script async src="https://www.googletagmanager.com/gtag/js?id=G-BCS8H7X41M"></script>

            <script is:inline>
              window.dataLayer = window.dataLayer || [];
              function gtag(){dataLayer.push(arguments);}
              gtag('js', new Date());

              gtag('config', 'G-BCS8H7X41M');
            </script>

            <!-- Standard meta tags -->
            <meta charset="UTF-8">
            <meta http-equiv="X-UA-Compatible" content="IE=edge">
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <meta name="description" content={description}>
            <meta name="keywords" content="">
            <link rel="canonical" href={`https://${client.domain}${Astro.url.pathname}`}>

            <!--Social Media Display-->
            <meta property="og:title" content={title} />
            <meta property="og:description" content={description} />
            <meta property="og:type" content="website" />
            <meta property="og:url" content={`https://${client.domain}${Astro.url.pathname}`} />
            <meta property="og:image" content="/assets/images/logo-small.png" />
            <meta property="og:image:secure_url" content="/assets/images/logo-small.png" />
    
            <!--Google Fonts - Playfair Display + Inter-->
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet">

            <!--Favicons-->
            <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicons/apple-touch-icon.png">
            <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicons/favicon-32x32.png?v1">
            <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicons/favicon-16x16.png">
            <link rel="manifest" href="/assets/favicons/site.webmanifest">
            <meta name="msapplication-TileColor" content="#da532c">
            <meta name="theme-color" content="#ffffff">

            <!-- JSON-LD Structured Data — LocalBusiness -->
            <script type="application/ld+json" set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "HomeAndConstructionBusiness",
                "name": "Boutique Shutters",
                "description": "Custom plantation shutters, designer shades, and motorized window treatments with expert installation serving Metro Atlanta.",
                "url": "https://www.boutiqueshutters.com",
                "telephone": "+1-404-966-7419",
                "email": "sales@boutiqueshutters.com",
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "Suwanee",
                    "addressRegion": "GA",
                    "postalCode": "30024",
                    "addressCountry": "US"
                },
                "geo": {
                    "@type": "GeoCoordinates",
                    "latitude": 34.0515,
                    "longitude": -84.0713
                },
                "areaServed": [
                    "Suwanee, GA", "Sugar Hill, GA", "Johns Creek, GA",
                    "Duluth, GA", "Alpharetta, GA", "Buford, GA",
                    "Lawrenceville, GA", "Peachtree Corners, GA", "Winder, GA"
                ],
                "priceRange": "$$",
                "aggregateRating": {
                    "@type": "AggregateRating",
                    "ratingValue": "4.9",
                    "reviewCount": "50",
                    "bestRating": "5"
                },
                "sameAs": [
                    "https://maps.app.goo.gl/314AZ4Dpz98b73GS8"
                ],
                "openingHoursSpecification": {
                    "@type": "OpeningHoursSpecification",
                    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
                    "opens": "08:00",
                    "closes": "18:00"
                },
                "image": "https://www.boutiqueshutters.com/assets/images/main-logo-compressed.png"
            })} />

            <!-- Additional head content -->
            <slot name="head" />

            <!-- Snipcart E-Commerce -->
            <link rel="preconnect" href="https://cdn.snipcart.com">
            <link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.7.1/default/snipcart.css" />
            <!-- Snipcart Custom Theme — Boutique Shutters Branded Checkout -->
            <style>
                /* === 1. FULL-PAGE CHECKOUT LAYOUT === */
                .snipcart-modal__container {
                    font-family: 'Inter', sans-serif !important;
                }
                .snipcart-layout {
                    background: #fafafa !important;
                }
                .snipcart-layout__content {
                    max-width: 1200px !important;
                    margin: 0 auto !important;
                }
                /* Make checkout full-width, not side panel */
                .snipcart-checkout {
                    max-width: 100% !important;
                }

                /* === 2. BRANDED HEADER === */
                .snipcart-cart-header {
                    background: #1a1a1a !important;
                    padding: 16px 24px !important;
                }
                .snipcart-cart-header__title {
                    color: #ffbf00 !important;
                    font-family: 'Playfair Display', serif !important;
                    font-size: 1.5rem !important;
                    font-weight: 700 !important;
                }
                .snipcart-cart-header__close-button {
                    color: white !important;
                }
                /* Add secure checkout indicator */
                .snipcart-cart-header::after {
                    content: '🔒 Secure Checkout';
                    color: #2ecc71;
                    font-size: 12px;
                    font-weight: 600;
                    font-family: 'Inter', sans-serif;
                    margin-left: 12px;
                }

                /* === 3. CHECKOUT STEP TITLES === */
                .snipcart-checkout-step__title {
                    font-family: 'Playfair Display', serif !important;
                    font-size: 1.5rem !important;
                    color: #1a1a1a !important;
                }
                .snipcart-checkout-step__icon {
                    background: #ffbf00 !important;
                    color: #000 !important;
                    font-weight: 700 !important;
                }
                .snipcart-checkout-step__icon--active {
                    background: #ffbf00 !important;
                }

                /* === 4. FORM FIELDS — GOLD FOCUS === */
                .snipcart-form__field .snipcart-input {
                    border: 2px solid #e0e0e0 !important;
                    border-radius: 0 !important;
                    font-family: 'Inter', sans-serif !important;
                    font-size: 14px !important;
                    padding: 12px !important;
                    transition: border-color 0.2s !important;
                }
                .snipcart-form__field .snipcart-input:focus {
                    border-color: #ffbf00 !important;
                    box-shadow: 0 0 0 1px #ffbf00 !important;
                    outline: none !important;
                }
                .snipcart-form__label {
                    font-weight: 600 !important;
                    color: #333 !important;
                    font-size: 13px !important;
                    text-transform: uppercase !important;
                    letter-spacing: 0.03em !important;
                }
                .snipcart-form__select {
                    border: 2px solid #e0e0e0 !important;
                    border-radius: 0 !important;
                }
                .snipcart-form__select:focus {
                    border-color: #ffbf00 !important;
                }

                /* === 5. PRIMARY BUTTONS — GOLD === */
                .snipcart-cart-button--highlight,
                .snipcart-button-primary,
                .snipcart-base-button--highlight,
                .snipcart-submit,
                .snipcart-base-button.is-icon-right,
                button.snipcart-button-primary,
                button.snipcart-submit {
                    background: #ffbf00 !important;
                    background-color: #ffbf00 !important;
                    color: #000 !important;
                    font-weight: 700 !important;
                    border: none !important;
                    border-radius: 0 !important;
                    text-transform: uppercase !important;
                    letter-spacing: 0.05em !important;
                    font-size: 15px !important;
                    padding: 14px 24px !important;
                    transition: background 0.3s !important;
                }
                .snipcart-cart-button--highlight:hover,
                .snipcart-button-primary:hover,
                .snipcart-base-button--highlight:hover,
                .snipcart-submit:hover,
                button.snipcart-submit:hover {
                    background: #856f00 !important;
                    background-color: #856f00 !important;
                }

                /* === 6. SECONDARY BUTTONS & LINKS === */
                .snipcart__actions--link,
                .snipcart-cart-button--secondary {
                    color: #ffbf00 !important;
                    font-weight: 600 !important;
                }
                .snipcart-cart-button--secondary {
                    border-color: #ffbf00 !important;
                }

                /* === 7. ITEM LINES === */
                .snipcart-item-line {
                    border-bottom: 1px solid #e8e8e8 !important;
                    padding: 16px 0 !important;
                }
                .snipcart-item-line__title {
                    font-weight: 700 !important;
                    font-size: 15px !important;
                    color: #1a1a1a !important;
                }
                .snipcart-item-line__header {
                    margin-bottom: 4px !important;
                }
                .snipcart-item-quantity__quantity {
                    border: 2px solid #e0e0e0 !important;
                    border-radius: 0 !important;
                    font-weight: 700 !important;
                }
                .snipcart-item-quantity__quantity:focus {
                    border-color: #ffbf00 !important;
                }

                /* === 8. ORDER SUMMARY === */
                .snipcart-cart-summary {
                    background: white !important;
                    border: 1px solid #e0e0e0 !important;
                }
                .snipcart-cart-summary-fees__amount {
                    font-weight: 700 !important;
                }
                .snipcart-cart-summary-fees__total {
                    font-size: 1.25rem !important;
                    font-weight: 900 !important;
                    color: #ffbf00 !important;
                }
                .snipcart-cart-summary-expanded-item__quantity {
                    background: #1a1a1a !important;
                    color: white !important;
                    border-radius: 0 !important;
                }

                /* === 9. PROMO CODE FIELD === */
                .snipcart-discount-box {
                    border: 2px solid #e0e0e0 !important;
                    border-radius: 0 !important;
                }
                .snipcart-discount-box__form {
                    display: flex !important;
                }
                .snipcart-discount-box__submit {
                    background: #1a1a1a !important;
                    color: #ffbf00 !important;
                    border-radius: 0 !important;
                    font-weight: 700 !important;
                    text-transform: uppercase !important;
                }
                .snipcart-discount-box__input {
                    border-radius: 0 !important;
                }
                .snipcart-discount-box__input:focus {
                    border-color: #ffbf00 !important;
                }

                /* === 10. PAYMENT & SECURITY === */
                .snipcart-payment-card-form {
                    border: 2px solid #e0e0e0 !important;
                    border-radius: 0 !important;
                }
                /* Add guarantee banner above payment */
                .snipcart-payment::before {
                    content: '✓ 100% Satisfaction Guaranteed — Free Shipping — Secure Encrypted Payment';
                    display: block;
                    text-align: center;
                    padding: 12px;
                    margin-bottom: 16px;
                    background: #f0fdf4;
                    color: #2ecc71;
                    font-size: 13px;
                    font-weight: 600;
                    border: 1px solid #d1fae5;
                }

                /* === 11. DELIVERY ESTIMATE === */
                .snipcart-cart-summary::after {
                    content: '📦 Estimated delivery: 2–4 weeks after order confirmation';
                    display: block;
                    text-align: center;
                    padding: 10px;
                    margin-top: 12px;
                    font-size: 12px;
                    color: #888;
                    border-top: 1px solid #e8e8e8;
                }

                /* === 12. FONTS === */
                .snipcart__font--secondary,
                .snipcart__font--std {
                    font-family: 'Inter', sans-serif !important;
                }

                /* === 13. REMOVE ITEM BUTTON === */
                .snipcart-item-line__remove {
                    color: #ccc !important;
                    transition: color 0.2s !important;
                }
                .snipcart-item-line__remove:hover {
                    color: #e74c3c !important;
                }

                /* === 14. FOOTER === */
                .snipcart__box--badge {
                    background: #1a1a1a !important;
                }

                /* === 15. ERROR STATES === */
                .snipcart-form__validation-error {
                    color: #e74c3c !important;
                    font-size: 12px !important;
                }
                .snipcart-input--invalid {
                    border-color: #e74c3c !important;
                }

                /* === 16. SNIPCART INPUT UNDERLINE STYLE OVERRIDE === */
                .snipcart-form__field input,
                .snipcart-form__field select {
                    border-bottom: 2px solid #e0e0e0 !important;
                }
                .snipcart-form__field input:focus,
                .snipcart-form__field select:focus {
                    border-bottom-color: #ffbf00 !important;
                }
                /* Step number circle */
                .snipcart-checkout-step__col {
                    align-items: center !important;
                }
                .snipcart-checkout-step__number {
                    background: #ffbf00 !important;
                    color: #000 !important;
                    font-weight: 700 !important;
                }
                /* Edit link gold */
                .snipcart-cart-summary__edit-link {
                    color: #ffbf00 !important;
                }
                /* Total in order summary */
                .snipcart-cart-summary__content .snipcart__font--bold {
                    font-weight: 900 !important;
                }

                /* === 17. LOADING STATES === */
                .snipcart__loading-overlay {
                    background: rgba(26, 26, 26, 0.8) !important;
                }
                .snipcart__loading-overlay__content {
                    color: #ffbf00 !important;
                }
            </style>

            <title>Boutique Shutters</title>

            <!-- Sitewide Scripts -->
            <script src="@js/nav.js"></script>
        </head>
        <body>
            <!--Screen reader skip main nav-->
            <a class="skip" aria-label="skip to main content" href="#main">Click To Skip To Main Content</a>
    
            <Header />
            <main id="main">
                <slot/>
            </main>
            <Footer />
            <LeadFormModal />
            <CartEnhancements />
            <!-- Snipcart Container -->
            <div hidden id="snipcart" data-api-key="YTlhNzJlZmEtNjdmNC00MDk3LTg3ZjQtMmNhYTlkNjNjNmRmNjM5MDk3ODAxMTQwMzE1MjI3" data-config-modal-style="side" data-config-add-product-behavior="none"></div>
            <script is:inline src="https://cdn.snipcart.com/themes/v3.7.1/default/snipcart.js"></script>
            <script is:inline>
            // Inject Snipcart theme overrides AFTER Snipcart loads its own CSS
            function injectSnipcartTheme() {
                const id = 'snipcart-boutique-theme';
                if (document.getElementById(id)) return;
                const style = document.createElement('style');
                style.id = id;
                style.textContent = `
                    .snipcart-modal__container { font-family: 'Inter', sans-serif !important; }
                    .snipcart-layout { background: #fafafa !important; padding-top: 120px !important; }
                    .snipcart-layout__content { padding-top: 20px !important; }
                    .snipcart-cart-header { background: #1a1a1a !important; }
                    .snipcart-cart-header__title { color: #ffbf00 !important; font-family: 'Playfair Display', serif !important; font-size: 1.5rem !important; }
                    .snipcart-cart-header__close-button { color: white !important; }
                    .snipcart-checkout-step__title { font-family: 'Playfair Display', serif !important; font-size: 1.5rem !important; }
                    .snipcart-checkout-step__icon { background: #ffbf00 !important; color: #000 !important; }
                    .snipcart-button-primary, .snipcart-submit, .snipcart-base-button.is-icon-right, .snipcart-cart-button--highlight, .snipcart-base-button--highlight { background-color: #ffbf00 !important; color: #000 !important; font-weight: 700 !important; border: none !important; border-radius: 0 !important; text-transform: uppercase !important; letter-spacing: 0.05em !important; font-size: 15px !important; padding: 14px 24px !important; }
                    .snipcart-button-primary:hover, .snipcart-submit:hover, .snipcart-cart-button--highlight:hover { background-color: #856f00 !important; }
                    .snipcart__actions--link { color: #ffbf00 !important; }
                    .snipcart-cart-button--secondary { border-color: #ffbf00 !important; color: #ffbf00 !important; }
                    .snipcart-form__field input:focus, .snipcart-form__field select:focus, .snipcart-input:focus { border-color: #ffbf00 !important; box-shadow: 0 0 0 1px #ffbf00 !important; }
                    .snipcart-form__label { font-weight: 600 !important; text-transform: uppercase !important; letter-spacing: 0.03em !important; font-size: 13px !important; }
                    .snipcart-input { border-radius: 0 !important; }
                    .snipcart-form__select { border-radius: 0 !important; }
                    .snipcart-cart-summary-fees__total { font-size: 1.25rem !important; font-weight: 900 !important; color: #ffbf00 !important; }
                    .snipcart-cart-summary-expanded-item__quantity { background: #1a1a1a !important; color: white !important; border-radius: 0 !important; }
                    .snipcart-discount-box__submit { background: #1a1a1a !important; color: #ffbf00 !important; border-radius: 0 !important; }
                    .snipcart-item-line__title { font-weight: 700 !important; }
                    .snipcart-item-line__remove:hover { color: #e74c3c !important; }
                    .snipcart-item-quantity__quantity { border-radius: 0 !important; }
                    .snipcart-item-quantity__quantity:focus { border-color: #ffbf00 !important; }
                    .snipcart-payment::before { content: '✓ 100% Satisfaction Guaranteed — Free Shipping — Secure Payment'; display: block; text-align: center; padding: 12px; margin-bottom: 16px; background: #f0fdf4; color: #2ecc71; font-size: 13px; font-weight: 600; border: 1px solid #d1fae5; }
                    .snipcart-cart-summary::after { content: '📦 Estimated delivery: 2–4 weeks'; display: block; text-align: center; padding: 10px; margin-top: 12px; font-size: 12px; color: #888; border-top: 1px solid #e8e8e8; }
                    .snipcart-cart-summary__edit-link { color: #ffbf00 !important; }
                    .snipcart-cart-summary { overflow: visible !important; }
                    .snipcart-checkout { overflow: visible !important; }
                    .snipcart__box--badge { background: #1a1a1a !important; }
                    .snipcart__loading-overlay { background: rgba(26,26,26,0.8) !important; }
                `;
                document.body.appendChild(style);
            }
            // Inject when Snipcart is ready
            document.addEventListener('snipcart.ready', injectSnipcartTheme);
            // Also inject on any DOM change (Snipcart renders dynamically)
            var snipcartObserver = new MutationObserver(function() { injectSnipcartTheme(); });
            snipcartObserver.observe(document.body, { childList: true, subtree: true });
            // Fallback
            setTimeout(injectSnipcartTheme, 3000);
            </script>
        </body>
</html>

<script is:inline>
    function enableDarkMode() {
      document.body.classList.add("dark-mode");
      localStorage.setItem("theme", "dark");
    }
  
    function disableDarkMode() {
      document.body.classList.remove("dark-mode");
      localStorage.setItem("theme", "light");
    }
  
    function setTheme() {
      let theme = "light";
  
      if (localStorage.getItem("theme")) {
        theme = localStorage.getItem("theme");
      }
      else if (
        window.matchMedia &&
        window.matchMedia("(prefers-color-scheme: dark)").matches
      ) {
        theme = "dark";
      }
  
      theme === "dark" ? enableDarkMode() : disableDarkMode();
    }
  
    setTheme();
  
    document.addEventListener("astro:after-swap", setTheme);
  </script>