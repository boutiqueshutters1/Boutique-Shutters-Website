        }

        .cs-reviews-link {
            text-align: center;
            margin-top: (8/16rem);
        }
    }
}

/* Tablet - 768px */
@media only screen and (min-width: 48rem) {
    #testimonials-about {
        .cs-testimonials-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
}

/*-- -------------------------- -->
<---        About FAQ           -->
<--- -------------------------- -*/

/* Mobile - 360px */
@media only screen and (min-width: 0rem) {
    #about-faq {
        padding: var(--sectionPadding);

        .cs-container {
            width: 100%;
            max-width: (800/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: clamp(1.5rem, 3vw, 2rem);
        }

        .cs-content {
            text-align: center;
            width: 100%;

            .cs-title { margin: 0; }
        }

        .cs-faq-group {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: (8/16rem);
        }

        .cs-faq-item {
            border: 1px solid #e0e0e0;
            overflow: hidden;
        }

        .cs-faq-button {
            width: 100%;
            padding: (16/16rem) (20/16rem);
            background: white;
            border: none;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: (12/16rem);
            font-family: inherit;
            transition: background-color 0.3s;

            &:hover {
                background: #fafafa;
            }
        }

        .cs-faq-question {
            font-size: (16/16rem);
            font-weight: 700;
            text-align: left;
            color: var(--headerColor);
        }

        .cs-faq-icon {
            font-size: (18/16rem);
            color: var(--secondary);
            transition: transform 0.3s;
            flex-shrink: 0;
        }

        .cs-faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease, padding 0.3s ease;

            p {
                font-size: (15/16rem);
                line-height: 1.7em;
                color: var(--bodyTextColor);
                margin: 0;
                padding: 0 (20/16rem) (20/16rem);

                a {
                    color: var(--secondary);
                    font-weight: 600;
                }
            }
        }

        .cs-faq-item.cs-active {
            .cs-faq-icon {
                transform: rotate(180deg);
            }
            .cs-faq-answer {
                max-height: 300px;
            }
        }
    }
}

</style>

<script is:inline>
(function() {
    document.querySelectorAll('#about-faq .cs-faq-button').forEach(btn => {
        btn.addEventListener('click', () => {
            const item = btn.closest('.cs-faq-item');
            const wasActive = item.classList.contains('cs-active');
            // Close all
            document.querySelectorAll('#about-faq .cs-faq-item').forEach(i => i.classList.remove('cs-active'));
            // Toggle clicked
            if (!wasActive) item.classList.add('cs-active');
        });
    });
})();
</script>