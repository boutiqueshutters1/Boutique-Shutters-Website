---
import BaseLayout from "src/layouts/BaseLayout.astro";
import CTA from "@components/CTA.astro";

// Optimize our landing image and pass it as props to the BaseLayout (for preloading) and Landing (for rendering)
import {getOptimizedImage} from "@js/utils"
import landingImage from "@assets/images/landing.jpg" // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
const optimizedImage = await getOptimizedImage(landingImage)
---

<BaseLayout
  title="About Boutique Shutters & Shades | Custom Window Treatment Specialists | Gwinnett County, GA"
  description="Boutique Shutters & Shades is a Premium window treatment company specializing in plantation shutters, zebra shades, motorized, plantation shutters and exterior shades serving Metro Atlanta since 2019."
  preloadedImage = {optimizedImage}
>
<!-- ============================================ -->
<!--                   Banner                     -->
<!-- ============================================ -->

<div id="banner-1106">
    <div class="cs-container">
        <span class="cs-int-title">About</span>
        <div class="cs-breadcrumbs">
            <a href="/" class="cs-link">Home</a>
            <a href="/about" class="cs-link cs-active">About</a>
        </div>
    </div>
    <!--Background Image-->
    <picture class="cs-background">
        <!--Mobile Image-->
        <source media="(max-width: 600px)" srcset="/assets/images/shades/curtain-1-1280x568-d.webp">
        <!--Tablet and above Image-->
        <source media="(min-width: 601px)" srcset="/assets/images/shades/curtain-1-1280x568-d.webp">
        <img decoding="async" src="/assets/images/shades/curtain-1-1280x568-d.webp" alt="custom plantation shutters" width="1280" height="568" aria-hidden="true">
    </picture>
</div>

<!-- ============================================ -->
<!--                Side By Side                  -->
<!-- ============================================ -->

<section id="sbs-1640">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">About Boutique Shutters & Shades</span>
            <h2 class="cs-title">Transforming Metro Atlanta Homes with Premium Window Treatments</h2>
            <picture class="cs-picture">
                <!--Mobile Image-->
                <source media="(max-width: 600px)" srcset="/assets/images/zebra-shades/zebra-shades-about.jpg">
                <!--Tablet and above Image-->
                <source media="(min-width: 601px)" srcset="/assets/images/zebra-shades/zebra-shades-about.jpg">
                <img loading="lazy" decoding="async" src="/assets/images/zebra-shades/zebra-shades-about.jpg" alt="boutique shutters showroom" width="608" height="406">
            </picture>
        </div>
        <div class="cs-stats-group">
            <p class="cs-text">
                Since 2019, Boutique Shutters & Shades has become Metro Atlanta's trusted source for premium window treatments. We specialize in custom plantation shutters, designer shades, and smart motorized solutions that enhance both the beauty and functionality of your home.
            </p>
            <p class="cs-text">
                Our commitment goes beyond just selling window treatments. We provide comprehensive design consultations, precise measurements, and expert installation throughout Sugar Hill, Suwanee, Johns Creek, Alpharetta, Duluth, and Lawrenceville. Every project receives our personal attention, ensuring exceptional results that exceed your expectations.
            </p>
            <ul class="cs-stats">
                <li class="cs-stat">
                    <span class="cs-number">100+</span>
                    <span class="cs-desc">Homes Transformed</span>
                </li>
                <li class="cs-stat">
                    <span class="cs-number">4.9</span>
                    <span class="cs-desc">Google Rating</span>
                </li>
                <li class="cs-stat">
                    <span class="cs-number">100%</span>
                    <span class="cs-desc">Satisfaction</span>
                </li>
            </ul>
        </div>
    </div>
</section>

<!-- ============================================ -->
<!--              Our Process                      -->
<!-- ============================================ -->

<section id="our-process">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">How It Works</span>
            <h2 class="cs-title">Our Simple 4-Step Process</h2>
            <p class="cs-text">From your first call to final installation, we make it easy.</p>
        </div>
        <div class="cs-process-steps">
            <div class="cs-process-step">
                <span class="cs-step-number">1</span>
                <h3 class="cs-step-title">Free Consultation</h3>
                <p class="cs-step-text">We visit your home (or connect virtually) to understand your style, needs, and budget. We bring premium samples so you can see and feel the materials in your own space.</p>
            </div>
            <div class="cs-process-connector"></div>
            <div class="cs-process-step">
                <span class="cs-step-number">2</span>
                <h3 class="cs-step-title">Precise Measurement</h3>
                <p class="cs-step-text">Our specialist takes exact measurements of every window. No guesswork — precision is key to a perfect fit and flawless operation.</p>
            </div>
            <div class="cs-process-connector"></div>
            <div class="cs-process-step">
                <span class="cs-step-number">3</span>
                <h3 class="cs-step-title">Custom Fabrication</h3>
                <p class="cs-step-text">Your window treatments are custom-built to your exact specifications. We use only premium materials for lasting quality and beauty.</p>
            </div>
            <div class="cs-process-connector"></div>
            <div class="cs-process-step">
                <span class="cs-step-number">4</span>
                <h3 class="cs-step-title">Expert Installation</h3>
                <p class="cs-step-text">Our certified installers handle everything. We leave your home spotless and walk you through operation and care for your new treatments.</p>
            </div>
        </div>
    </div>
</section>

<!-- ============================================ -->
<!--           Core Values / Why Us                -->
<!-- ============================================ -->

<section id="core-values">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">Why Choose Us</span>
            <h2 class="cs-title">The Boutique Shutters & Shades Difference</h2>
        </div>
        <div class="cs-values-grid">
            <div class="cs-value-card">
                <span class="cs-value-icon">🏠</span>
                <h3 class="cs-value-title">Local & Owner-Operated</h3>
                <p class="cs-value-text">We're your neighbors in Metro Atlanta, not a national franchise. You work directly with the owner on every project.</p>
            </div>
            <div class="cs-value-card">
                <span class="cs-value-icon">✨</span>
                <h3 class="cs-value-title">Premium Materials Only</h3>
                <p class="cs-value-text">We never cut corners. Every product we offer is hand-selected for quality, durability, and timeless style.</p>
            </div>
            <div class="cs-value-card">
                <span class="cs-value-icon">🛠️</span>
                <h3 class="cs-value-title">White Glove Installation</h3>
                <p class="cs-value-text">Our certified installers treat your home with respect — precise work, clean job site, and a final walkthrough every time.</p>
            </div>
            <div class="cs-value-card">
                <span class="cs-value-icon">🤝</span>
                <h3 class="cs-value-title">Lifetime Support</h3>
                <p class="cs-value-text">Our relationship doesn't end at installation. We stand behind our work with warranty coverage and ongoing support.</p>
            </div>
        </div>
    </div>
</section>

<!-- ============================================ -->
<!--           Customer Testimonials               -->
<!-- ============================================ -->

<section id="testimonials-about">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">What Our Customers Say</span>
            <h2 class="cs-title">Real Reviews from Real Homeowners</h2>
        </div>
        <div class="cs-testimonials-grid">
            <div class="cs-testimonial">
                <div class="cs-stars">★★★★★</div>
                <p class="cs-quote">"Danny was incredibly professional and knowledgeable. He helped us choose the perfect shutters for our new home in Johns Creek. The installation was flawless and the finished product looks amazing!"</p>
                <span class="cs-reviewer">— Sarah M., Johns Creek</span>
            </div>
            <div class="cs-testimonial">
                <div class="cs-stars">★★★★★</div>
                <p class="cs-quote">"We got motorized shades for our living room and couldn't be happier. The smart home integration works perfectly with our Alexa. Boutique Shutters & Shades made the whole process easy from start to finish."</p>
                <span class="cs-reviewer">— Michael T., Sugar Hill</span>
            </div>
            <div class="cs-testimonial">
                <div class="cs-stars">★★★★★</div>
                <p class="cs-quote">"Best decision we made for our home renovation. The plantation shutters transformed every room. Danny's attention to detail and follow-up after installation really sets this company apart."</p>
                <span class="cs-reviewer">— Jennifer L., Suwanee</span>
            </div>
        </div>
        <div class="cs-reviews-link">
            <a href="https://maps.app.goo.gl/314AZ4Dpz98b73GS8" target="_blank" rel="noopener noreferrer" class="cs-button-solid">Read All Reviews on Google</a>
        </div>
    </div>
</section>

<!-- ============================================ -->
<!--                    FAQ                        -->
<!-- ============================================ -->

<section id="about-faq">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">Common Questions</span>
            <h2 class="cs-title">Frequently Asked Questions</h2>
        </div>
        <div class="cs-faq-group">
            <div class="cs-faq-item cs-active">
                <button class="cs-faq-button" type="button">
                    <span class="cs-faq-question">What areas do you serve?</span>
                    <span class="cs-faq-icon">▾</span>
                </button>
                <div class="cs-faq-answer">
                    <p>We serve Sugar Hill, Suwanee, Johns Creek, Duluth, Alpharetta, Lawrenceville, Buford, Peachtree Corners, Winder, and the greater Metro Atlanta area. Free in-home consultations are available throughout our service area.</p>
                </div>
            </div>
            <div class="cs-faq-item">
                <button class="cs-faq-button" type="button">
                    <span class="cs-faq-question">How much do custom shutters cost?</span>
                    <span class="cs-faq-icon">▾</span>
                </button>
                <div class="cs-faq-answer">
                    <p>Pricing varies based on window size, material, customization, and installation. We offer a <a href="/book">free in-home consultation</a> where we'll measure your windows and provide an accurate quote tailored to your project.</p>
                </div>
            </div>
            <div class="cs-faq-item">
                <button class="cs-faq-button" type="button">
                    <span class="cs-faq-question">How long does installation take?</span>
                    <span class="cs-faq-icon">▾</span>
                </button>
                <div class="cs-faq-answer">
                    <p>From order to installation is typically 2-4 weeks depending on the product. The actual installation usually takes just a few hours for most homes. We'll give you an exact timeline during your consultation.</p>
                </div>
            </div>
            <div class="cs-faq-item">
                <button class="cs-faq-button" type="button">
                    <span class="cs-faq-question">Do you offer financing?</span>
                    <span class="cs-faq-icon">▾</span>
                </button>
                <div class="cs-faq-answer">
                    <p>Yes! We offer flexible financing through Wisetack and Klarna. Apply during your consultation for quick approval and affordable monthly payments. No obligation to proceed.</p>
                </div>
            </div>
            <div class="cs-faq-item">
                <button class="cs-faq-button" type="button">
                    <span class="cs-faq-question">What warranty do you provide?</span>
                    <span class="cs-faq-icon">▾</span>
                </button>
                <div class="cs-faq-answer">
                    <p>All our products come with manufacturer warranties, and we stand behind our installation work. Visit our <a href="/warranty">warranty page</a> for full details on coverage for each product line.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<CTA/>

</BaseLayout>

<style lang="less">
/*-- -------------------------- -->
<---          Banner            -->
<--- -------------------------- -*/

/* Mobile - 360px */
@media only screen and (min-width: 0rem) {
    #banner-1106 {
        padding: var(--sectionPadding);
        padding-top: (250/16rem);
        padding-bottom: (120/16rem);
        /* clips the line from causing overflow issues for going off screen */
        overflow: hidden;
        position: relative;
        z-index: 1;

        .cs-container {
            text-align: center;
            width: 100%;
            max-width: (1280/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            flex-direction: column;
            gap: (12/16rem);
        }

        .cs-int-title {
            /* 39px - 61px */
            font-size: clamp(2.4375rem, 6.4vw, 3.8125rem);
            font-weight: 900;
            line-height: 1.2em;
            text-align: inherit;
            margin: 0;
            color: var(--bodyTextColorWhite);
            position: relative;
        }

        .cs-breadcrumbs {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .cs-link {
            font-size: (16/16rem);
            line-height: 1.2em;
            text-decoration: none;
            color: var(--bodyTextColorWhite);
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;

            &:last-of-type {
                /* remove the chevron on the last list item */
                &::after {
                    display: none;
                }
            }

            &:after {
                /* chevron */
                content: "";
                width: (7/16rem);
                height: (12/16rem);
                margin: 0 (16/16rem);
                background: url("https://csimg.nyc3.cdn.digitaloceanspaces.com/Icons/white-chev.svg");
                background-size: contain;
                background-position: center;
                background-repeat: no-repeat;
                position: relative;
                display: block;
            }

            &.cs-active {
                color: var(--secondary);
            }
        }

        .cs-background {
            width: 100%;
            height: 100%;
            display: block;
            position: absolute;
            top: 0;
            left: 0;
            z-index: -1;

            &:before {
                /* background color overlay */
                content: "";
                position: absolute;
                display: block;
                height: 100%;
                width: 100%;
                background: -moz-linear-gradient(
                    left,
                    rgba(26, 26, 26, 0.94) 0%,
                    rgba(26, 26, 26, 0) 100%
                ); /* FF3.6-15 */
                background: -webkit-linear-gradient(
                    left,
                    rgba(26, 26, 26, 0.94) 0%,
                    rgba(26, 26, 26, 0) 100%
                ); /* Chrome10-25,Safari5.1-6 */
                opacity: 1;
                top: 0;
                left: 0;
                z-index: 1;
            }

            img {
                position: absolute;
                top: 0;
                left: 0;
                height: 100%;
                width: 100%;
                /* Makes img tag act as a background image */
                object-fit: cover;
            }
        }
    }
}

/*-- -------------------------- -->
<---        Side By Side        -->
<--- -------------------------- -*/

/* Mobile - 360px */
@media only screen and (min-width: 0rem) {
    #sbs-1640 {
        padding: var(--sectionPadding);
        /*background-color: #111926;*/
        overflow: hidden;
        
        .cs-container {
            width: 100%;
            /* changes to 1280px at tablet */
            max-width: (584/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            /* 48px - 64px */
            gap: clamp(3rem, 6vw, 4rem);
        }

        .cs-content {
            /* set text align to left if content needs to be left aligned */
            text-align: left;
            width: 100%;
            max-width: (630/16rem);
            display: flex;
            flex-direction: column;
            /* centers content horizontally, set to flex-start to left align */
            align-items: flex-start;
            position: relative;
            z-index: 10;
        }

        .cs-title {
            margin: 0 0 (40/16rem) 0;
            /*color: var(--bodyTextColorWhite);*/
        }

        .cs-text {
            margin-bottom: (16/16rem);
            /*color: var(--bodyTextColorWhite);*/
            //opacity: .8;

            &:last-of-type {
                margin-bottom: (32/16rem);
            }
        }

        .cs-picture {
            width: 100%;
            height: auto;
            min-height: (420/16rem);
            display: block;
            position: relative;
            z-index: 1;

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                position: absolute;
                top: 0;
                left: 0;
            }
        }

        .cs-stats-group {
            width: 100%;
            max-width: (570/16rem);
            display: flex;
            flex-direction: column;
        }

        .cs-stats {
            width: 100%;
            max-width: (630/16rem);
            padding: 0;
            margin: 0;
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            row-gap: (24/16rem);
            column-gap: (12/16rem);
        }
        
        .cs-stat {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            grid-column: span 4;
            flex-direction: column;
            align-self: stretch;
            align-content: space-between;
        }
    
        .cs-number {
            /* 39px - 61px */
            font-size: clamp(2.4375rem, 5vw, 3.8125rem);
            line-height: 1.2em;
            font-weight: 900;
            text-align: left;
            /*color: var(--bodyTextColorWhite);*/
            display: block;
            margin: 0 0 (4/16rem) 0;
        }
    
        .cs-desc {
            font-size: (16/16rem);
            line-height: 1.5em;
            font-weight: 700;
            text-align: left;
            /* auto margin top will push text to bottom if there's only one line */
            margin: 0;
            /*color: #fff;*/
        }
    }
}

/* Tablet - 768px */
@media only screen and (min-width: 48rem) {
    #sbs-1640 {
        .cs-container {
            max-width: (1280/16rem);
            flex-direction: row;
            justify-content: space-between;
            align-items: stretch;
        }

        .cs-stats-group {
            /* 52px - 90px */
            margin-bottom: clamp(3.25rem, 7vw, 5.625rem);
            /* 60px - 120px */
            padding-top: clamp(3.75rem, 10vw, 7.5rem);
            /* 60px - 80px */
            padding-bottom: clamp(3.75rem, 8vw, 5rem);
            position: relative;
            z-index: 1;

            &:before {
                content: '';
                width: 200vw;
                height: 100%;
                /*background: #fff;*/
                opacity: 1;
                position: absolute;
                display: block;
                top: 100%;
                left: -100%;
                z-index: -1;
                transform: translateX(-50%);
            }
        }

        .cs-picture {
            height: 100%;
        }
    }
}

/*-- -------------------------- -->
<---       Our Process          -->
<--- -------------------------- -*/

/* Mobile - 360px */
@media only screen and (min-width: 0rem) {
    #our-process {
        padding: var(--sectionPadding);
        background: #1a1a1a;

        .cs-container {
            width: 100%;
            max-width: (1280/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: clamp(2rem, 4vw, 3rem);
        }

        .cs-content {
            text-align: center;
            width: 100%;
            max-width: (700/16rem);

            .cs-title { color: #fff; margin: 0 0 (12/16rem) 0; }
            .cs-text { color: #a7a7a7; margin: 0; }
        }

        .cs-process-steps {
            width: 100%;
            max-width: (900/16rem);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0;
        }

        .cs-process-step {
            text-align: center;
            padding: (24/16rem);
        }

        .cs-step-number {
            font-size: (20/16rem);
            font-weight: 900;
            color: #000;
            background: var(--secondary);
            width: (48/16rem);
            height: (48/16rem);
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 50%;
            margin: 0 auto (12/16rem);
        }

        .cs-step-title {
            font-size: (18/16rem);
            font-weight: 700;
            color: #fff;
            margin: 0 0 (8/16rem) 0;
        }

        .cs-step-text {
            font-size: (14/16rem);
            line-height: 1.6em;
            color: #a7a7a7;
            margin: 0;
            max-width: (280/16rem);
        }

        .cs-process-connector {
            width: 2px;
            height: (24/16rem);
            background: var(--secondary);
            opacity: 0.4;
        }
    }
}

/* Tablet - 768px */
@media only screen and (min-width: 48rem) {
    #our-process {
        .cs-process-steps {
            flex-direction: row;
            align-items: flex-start;
        }

        .cs-process-connector {
            width: (40/16rem);
            height: 2px;
            margin-top: (48/16rem);
            flex-shrink: 0;
        }

        .cs-process-step {
            flex: 1;
        }
    }
}

/*-- -------------------------- -->
<---       Core Values          -->
<--- -------------------------- -*/

/* Mobile - 360px */
@media only screen and (min-width: 0rem) {
    #core-values {
        padding: var(--sectionPadding);

        .cs-container {
            width: 100%;
            max-width: (1280/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: clamp(1.5rem, 3vw, 2rem);
        }

        .cs-content {
            text-align: center;
            width: 100%;
            max-width: (700/16rem);

            .cs-title { margin: 0; }
        }

        .cs-values-grid {
            width: 100%;
            display: grid;
            grid-template-columns: 1fr;
            gap: (16/16rem);
        }

        .cs-value-card {
            background: #f7f7f7;
            padding: (28/16rem) (24/16rem);
            text-align: center;
            border-bottom: 3px solid var(--secondary);
