---
import BaseLayout from "src/layouts/BaseLayout.astro";
import CTA from "@components/CTA.astro";
import Estimator from "@components/Estimator.astro";
import ProductSchema from "@components/ProductSchema.astro";

import {getOptimizedImage} from "@js/utils"
import landingImage from "@assets/images/landing.jpg"
const optimizedImage = await getOptimizedImage(landingImage)
---

<BaseLayout
  title="Custom Blinds | Faux Wood & Wood Blinds | Boutique Shutters"
  description="Premium custom blinds for every room. Faux wood and wood blinds with professional measurement and installation. Affordable, durable, and stylish. Free consultations in Metro Atlanta."
  preloadedImage={optimizedImage}
>
<ProductSchema
    slot="head"
    name="Custom Window Blinds"
    description="Premium faux wood and wood blinds custom-fitted for your windows. Durable, affordable, and available in multiple colors and slat sizes."
    url="/blinds"
    image="/assets/images/gallery/blinds-bay-window-dining.jpg"
    lowPrice="50"
    highPrice="200"
/>
<!-- ============================================ -->
<!--                   Banner                     -->
<!-- ============================================ -->

<div id="banner-1106">
    <div class="cs-container">
        <span class="cs-int-title">Custom Blinds</span>
        <div class="cs-breadcrumbs">
            <a href="/" class="cs-link">Home</a>
            <a href="/blinds" class="cs-link cs-active">Blinds</a>
        </div>
    </div>
    <picture class="cs-background">
        <source media="(max-width: 600px)" srcset="/assets/images/gallery/blinds-bay-window-dining.jpg">
        <source media="(min-width: 601px)" srcset="/assets/images/gallery/blinds-bay-window-dining.jpg">
        <img decoding="async" src="/assets/images/gallery/blinds-bay-window-dining.jpg" alt="custom blinds in dining room bay window" width="1280" height="568" aria-hidden="true">
    </picture>
</div>

<!-- ============================================ -->
<!--                Side By Side                  -->
<!-- ============================================ -->

<section id="sbs-1598">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">Classic & Versatile</span>
            <h2 class="cs-title">Custom Blinds for Every Room in Your Home</h2>
            <p class="cs-text">
                Our premium blinds combine classic style with modern durability. Available in faux wood and real wood options, each blind is custom-measured and cut to fit your windows perfectly. With horizontal slats that tilt for precise light control, blinds remain one of the most versatile and affordable window treatment options.
            </p>
            <p class="cs-text">
                Choose from a wide range of colors, stains, and slat sizes to match any décor. Our faux wood blinds are moisture-resistant and ideal for kitchens, bathrooms, and high-humidity areas, while our wood blinds add natural warmth and elegance to living rooms and bedrooms.
            </p>
            <!-- Best For Tags -->
            <div class="cs-best-for">
                <span class="cs-best-for-label">Best For:</span>
                <span class="cs-best-for-tag">Bedrooms</span>
                <span class="cs-best-for-tag">Kitchens</span>
                <span class="cs-best-for-tag">Bathrooms</span>
                <span class="cs-best-for-tag">Home Offices</span>
                <span class="cs-best-for-tag">Living Rooms</span>
            </div>
            <picture class="cs-picture cs-picture1">
                <source media="(max-width: 600px)" srcset="/assets/images/gallery/blinds-large-bedroom.jpg">
                <source media="(min-width: 601px)" srcset="/assets/images/gallery/blinds-large-bedroom.jpg">
                <img loading="lazy" decoding="async" src="/assets/images/gallery/blinds-large-bedroom.jpg" alt="custom faux wood blinds in bedroom" width="608" height="406">
            </picture>
        </div>
        <div class="cs-stats-group">
            <picture class="cs-picture cs-picture2">
                <source media="(max-width: 600px)" srcset="/assets/images/gallery/blinds-dining-wainscot.jpg">
                <source media="(min-width: 601px)" srcset="/assets/images/gallery/blinds-dining-wainscot.jpg">
                <img loading="lazy" decoding="async" src="/assets/images/gallery/blinds-dining-wainscot.jpg" alt="blinds in dining room with wainscoting" width="608" height="662">
            </picture>
            <ul class="cs-stats">
                <li class="cs-stat">
                    <span class="cs-number">10+</span>
                    <span class="cs-desc">Color & stain options</span>
                </li>
                <li class="cs-stat">
                    <span class="cs-number">100%</span>
                    <span class="cs-desc">Custom measured & fitted</span>
                </li>
                <li class="cs-stat">
                    <span class="cs-number">2-3 Weeks</span>
                    <span class="cs-desc">Average turnaround</span>
                </li>
            </ul>
        </div>
    </div>
</section>

<!-- ============================================ -->
<!--            Side By Side Reverse              -->
<!-- ============================================ -->

<section id="sbsr-1599">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">Durable & Affordable</span>
            <h2 class="cs-title">Built to Last, Priced to Please</h2>
            <p class="cs-text">
                Our blinds are engineered for everyday life. Faux wood blinds resist warping, fading, and moisture damage — making them the smart choice for kitchens, bathrooms, and laundry rooms. Real wood blinds offer the rich, natural beauty that only genuine hardwood can provide, with protective finishes that ensure lasting durability.
            </p>
            <p class="cs-text">
                Every installation includes professional measurement, custom fabrication, and expert fitting by our certified team. We handle bay windows, French doors, and specialty shapes that big-box stores can't match. The result is a clean, polished look that transforms any room.
            </p>
            <picture class="cs-picture cs-picture1">
                <source media="(max-width: 600px)" srcset="/assets/images/gallery/blinds-fireplace.jpg">
                <source media="(min-width: 601px)" srcset="/assets/images/gallery/blinds-fireplace.jpg">
                <img loading="lazy" decoding="async" src="/assets/images/gallery/blinds-fireplace.jpg" alt="blinds next to fireplace in living room" width="608" height="406">
            </picture>
        </div>
        <div class="cs-stats-group">
            <picture class="cs-picture cs-picture2">
                <source media="(max-width: 600px)" srcset="/assets/images/gallery/blinds-tall-living.jpg">
                <source media="(min-width: 601px)" srcset="/assets/images/gallery/blinds-tall-living.jpg">
                <img loading="lazy" decoding="async" src="/assets/images/gallery/blinds-tall-living.jpg" alt="two-story living room blinds installation" width="608" height="662">
            </picture>
            <ul class="cs-stats">
                <li class="cs-stat">
                    <span class="cs-number">100+</span>
                    <span class="cs-desc">Satisfied homeowners</span>
                </li>
                <li class="cs-stat">
                    <span class="cs-number">Moisture</span>
                    <span class="cs-desc">Resistant faux wood option</span>
                </li>
                <li class="cs-stat">
                    <span class="cs-number">5-Star</span>
                    <span class="cs-desc">Customer satisfaction rating</span>
                </li>
            </ul>
        </div>
    </div>
</section>

<Estimator
    productName="Blinds"
    pricingModel="perWindow"
    options={[
        { name: "Faux Wood Blinds", pricePerSqFt: 80 },
        { name: "Real Wood Blinds", pricePerSqFt: 120 },
    ]}
    note="Pricing varies by window size, slat width, and material. Get your exact quote with a free consultation."
/>

<CTA/>

</BaseLayout>

<style lang="less">
/*-- -------------------------- -->
<---          Banner            -->
<--- -------------------------- -*/
@media only screen and (min-width: 0rem) {
    #banner-1106 {
        padding: var(--sectionPadding);
        padding-top: (250/16rem);
        padding-bottom: (120/16rem);
        overflow: hidden;
        position: relative;
        z-index: 1;

        .cs-container {
            text-align: center;
            width: 100%;
            max-width: (1280/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            gap: (12/16rem);
        }

        .cs-int-title {
            font-size: clamp(2.4375rem, 6.4vw, 3.8125rem);
            font-weight: 900;
            line-height: 1.2em;
            text-align: inherit;
            margin: 0;
            color: var(--bodyTextColorWhite);
            position: relative;
        }

        .cs-breadcrumbs {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .cs-link {
            font-size: (16/16rem);
            line-height: 1.2em;
            text-decoration: none;
            color: var(--bodyTextColorWhite);
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;

            &:last-of-type::after { display: none; }

            &:after {
                content: "";
                width: (7/16rem);
                height: (12/16rem);
                margin: 0 (16/16rem);
                background: url("https://csimg.nyc3.cdn.digitaloceanspaces.com/Icons/white-chev.svg");
                background-size: contain;
                background-position: center;
                background-repeat: no-repeat;
                position: relative;
                display: block;
            }

            &.cs-active {
                color: var(--secondary);
            }
        }

        .cs-background {
            width: 100%;
            height: 100%;
            display: block;
            position: absolute;
            top: 0;
            left: 0;
            z-index: -1;

            &:before {
                content: "";
                position: absolute;
                display: block;
                height: 100%;
                width: 100%;
                background: linear-gradient(to right, rgba(26, 26, 26, 0.94) 0%, rgba(26, 26, 26, 0) 100%);
                opacity: 1;
                top: 0;
                left: 0;
                z-index: 1;
            }

            img {
                position: absolute;
                top: 0;
                left: 0;
                height: 100%;
                width: 100%;
                object-fit: cover;
            }
        }
    }
}

/*-- -------------------------- -->
<---        Side By Side        -->
<--- -------------------------- -*/
@media only screen and (min-width: 0rem) {
    #sbs-1598 {
        padding: var(--sectionPadding);

        .cs-container {
            width: 100%;
            max-width: (584/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: clamp(3rem, 6vw, 4rem);
        }

        .cs-content {
            text-align: left;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .cs-text {
            margin-bottom: (16/16rem);
            &:last-of-type { margin-bottom: (32/16rem); }
        }

        .cs-picture {
            width: 100%;
            display: block;
            position: relative;
            z-index: 1;
            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                position: absolute;
                top: 0;
                left: 0;
            }
        }

        .cs-picture1 {
            height: 95vw;
            max-height: (400/16rem);
        }

        .cs-picture2 {
            height: 111vw;
            max-height: (500/16rem);
        }

        .cs-stats-group {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: clamp(1.75rem, 3vw, 2.5rem);
        }

        .cs-stats {
            width: 100%;
            max-width: (630/16rem);
            padding: 0;
            margin: 0;
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            row-gap: (24/16rem);
            column-gap: (12/16rem);
        }

        .cs-stat {
            list-style: none;
            margin: 0;
            padding: 0 0 (24/16rem) 0;
            display: flex;
            grid-column: span 4;
            flex-direction: column;
            align-self: stretch;
            align-content: space-between;
        }

        .cs-number {
            font-size: clamp(1.9375rem, 3vw, 2.4375rem);
            line-height: 1.2em;
            font-weight: 700;
            text-align: left;
            display: block;
            margin: 0 0 (4/16rem) 0;
        }

        .cs-desc {
            font-size: (16/16rem);
            line-height: 1.5em;
            font-weight: 400;
            text-align: left;
            margin: 0;
        }
    }
}

@media only screen and (min-width: 48rem) {
    #sbs-1598 {
        .cs-container {
            max-width: (1280/16rem);
            flex-direction: row;
            justify-content: space-between;
            align-items: stretch;
        }
        .cs-picture1 {
            min-height: clamp(21.25rem, 35vw, 28.75rem);
            height: 100%;
            max-height: 100%;
        }
        .cs-picture2 {
            min-height: clamp(33.125rem, 45vw, 41.25rem);
            height: 100%;
            max-height: 100%;
        }
    }
}

/*-- -------------------------- -->
<---   Side By Side Reverse     -->
<--- -------------------------- -*/
@media only screen and (min-width: 0rem) {
