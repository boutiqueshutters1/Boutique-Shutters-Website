---
import BaseLayout from "src/layouts/BaseLayout.astro";
import CTA from "@components/CTA.astro";
import Projects from "@components/Projects.astro";
import FAQ from "@components/FAQ.astro";
import ComparisonChart from "@components/ComparisonChart.astro";

---

<BaseLayout
  title="Custom Plantation Shutters & Window Treatments | Boutique Shutters"
  description="Expert plantation shutters, designer shades & motorized blinds in Suwanee, Johns Creek & Sugar Hill. Custom design, professional install. Free quote!"
>

<!-- ============================================ -->
<!--                    Hero                      -->
<!-- ============================================ -->

<section id="hero-1059">
    <div class="cs-container">
        <div class="cs-content">
            <h1 class="cs-title">Custom Plantation Shutters & Designer Window Treatments</h1>
            <p class="cs-text">
                Premium window shutters, designer shades, and motorized blinds with expert installation. Transform your home with custom-designed window treatments from Boutique Shutters—serving Metro Atlanta homeowners with personalized service, superior craftsmanship, and a commitment to perfection in every installation.
            </p>
            <div class="cs-hero-paths">
                <a href="/book" class="cs-path-card" data-lead-form>
                    <span class="cs-path-icon">🏠</span>
                    <span class="cs-path-title">Professional Install</span>
                    <span class="cs-path-desc">Free in-home consultation, expert measurement & installation by our certified team</span>
                    <span class="cs-path-cta">Book Free Estimate →</span>
                </a>
                <a href="/configure" class="cs-path-card cs-path-diy">
                    <span class="cs-path-icon">🛒</span>
                    <span class="cs-path-title">DIY — Order Online</span>
                    <span class="cs-path-desc">Configure your custom window treatments, order online & install yourself</span>
                    <span class="cs-path-cta">Configure & Buy →</span>
                </a>
            </div>
            <a href="https://maps.app.goo.gl/314AZ4Dpz98b73GS8" target="_blank" rel="noopener noreferrer" class="cs-hero-badge">
                <img src="https://csimg.nyc3.digitaloceanspaces.com/Reviews/stars-yellow.svg" alt="5 stars" width="96" height="16">
                <span>4.9 from 50+ Google Reviews</span>
            </a>
        </div>
    </div>

    <!-- Background Image -->
    <picture class="cs-background">
        <source media="(max-width: 600px)" srcset="/assets/images/shutters/plantation-shutters-430x723-m.webp">
        <source media="(min-width: 601px)" srcset="/assets/images/shutters/plantation-shutters-1800x860-d.webp">
        <img decoding="async" src="/assets/images/shutters/plantation-shutters-1800x860-d.webp" alt="custom plantation shutters installation in Suwanee living room" width="2250" height="1500" aria-hidden="true">
    </picture>
</section>

<!-- ============================================ -->
<!--              How It Works                     -->
<!-- ============================================ -->

<section id="how-it-works">
    <div class="cs-container">
        <div class="cs-step">
            <span class="cs-step-number">1</span>
            <h3 class="cs-step-title">Book</h3>
            <p class="cs-step-text">Schedule your free in-home or virtual consultation</p>
        </div>
        <span class="cs-arrow">&#10140;</span>
        <div class="cs-step">
            <span class="cs-step-number">2</span>
            <h3 class="cs-step-title">Design</h3>
            <p class="cs-step-text">We measure, show samples, and create your custom plan</p>
        </div>
        <span class="cs-arrow">&#10140;</span>
        <div class="cs-step">
            <span class="cs-step-number">3</span>
            <h3 class="cs-step-title">Install</h3>
            <p class="cs-step-text">Professional installation, usually in one visit</p>
        </div>
    </div>
</section>

<!-- ============================================ -->
<!--             Side By Side Reverse             -->
<!-- ============================================ -->

<section id="sbsr-2169">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">Why Choose Us</span>
            <h2 class="cs-title">Why Homeowners Choose Boutique Shutters</h2>
            <p class="cs-text">
                Boutique Shutters has been the trusted choice for custom window treatments in Metro Atlanta. We're not a big-box store or national franchise—we're a locally-owned business that takes pride in transforming homes throughout Suwanee, Johns Creek, Sugar Hill, and surrounding communities. We understand the unique architectural styles found throughout Metro Atlanta and provide complimentary in-home consultations where we measure your windows, discuss your vision, and provide honest recommendations tailored to your home and budget.
            </p>
            <ul class="cs-stats">
                <li class="cs-stat">
                    <span class="cs-stat-icon">🏠</span>
                    <span class="cs-number">100+</span>
                    <span class="cs-desc">Homes Transformed</span>
                </li>
                <li class="cs-stat">
                    <span class="cs-stat-icon">⭐</span>
                    <span class="cs-number">4.9</span>
                    <span class="cs-desc">Google Rating</span>
                </li>
                <li class="cs-stat">
                    <span class="cs-stat-icon">✅</span>
                    <span class="cs-number">100%</span>
                    <span class="cs-desc">Satisfaction</span>
                </li>
            </ul>
        </div>
        <div class="cs-media-row">
            <div class="cs-media-video">
                <video autoplay muted loop playsinline poster="/assets/images/zebra-shades/zebra-shades-630x400-d.webp">
                    <source src="/assets/videos/why-choose-us.mp4" type="video/mp4">
                </video>
            </div>
            <div class="cs-media-photo">
                <img loading="lazy" decoding="async" src="/assets/images/shutters/danny-consultation.jpg" alt="Boutique Shutters owner Danny during a window treatment consultation">
            </div>
        </div>
    </div>
</section>

<!-- ============================================ -->
<!--            Side By Side Reverse              -->
<!-- ============================================ -->

<section id="sbsr-1599">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">Expert Installation</span>
            <h2 class="cs-title">Professional Installation Makes All The Difference</h2>
            <p class="cs-text">
                We partner with industry-leading manufacturers to bring you premium plantation shutters, designer shades, and motorized window treatments that stand the test of time. Every installation is backed by our commitment to craftsmanship and a comprehensive warranty for your peace of mind. Unlike online retailers or DIY big-box solutions, we handle every step of the process: custom design consultation, precise measurements, expert installation, and ongoing support. Your satisfaction is our priority, and we don't consider a job complete until your windows look absolutely perfect.
            </p>
        </div>
        <div class="cs-stats-group">
            <!-- Before/After Slider -->
            <div class="cs-ba-slider" id="ba-slider">
                <div class="cs-ba-before">
                    <img loading="lazy" decoding="async" src="/assets/images/shutters/shutters-2-608x406-d.webp" alt="before professional shutter installation" width="608" height="406">
                    <span class="cs-ba-label cs-ba-label-before">Before</span>
                </div>
                <div class="cs-ba-after">
                    <img loading="lazy" decoding="async" src="/assets/images/projects/shutter-project-5-608x662-d.webp" alt="after professional shutter installation" width="608" height="662">
                    <span class="cs-ba-label cs-ba-label-after">After</span>
                </div>
                <div class="cs-ba-handle" id="ba-handle">
                    <span class="cs-ba-handle-line"></span>
                    <span class="cs-ba-handle-circle">&#8596;</span>
                    <span class="cs-ba-handle-line"></span>
                </div>
            </div>
            <ul class="cs-stats">
                <li class="cs-stat">
                    <span class="cs-number">100+</span>
                    <span class="cs-desc">Homes Transformed</span>
                </li>
                <li class="cs-stat">
                    <span class="cs-number">5-Star</span>
                    <span class="cs-desc">Customer Reviews</span>
                </li>
                <li class="cs-stat">
                    <span class="cs-number">100%</span>
                    <span class="cs-desc">Satisfaction Guarantee</span>
                </li>
            </ul>
        </div>
    </div>
</section>

