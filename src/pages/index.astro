---
import BaseLayout from "src/layouts/BaseLayout.astro";
import CTA from "@components/CTA.astro";
import Projects from "@components/Projects.astro";
// Optimize our landing image and pass it as props to the BaseLayout (for preloading) and Landing (for rendering)
import {getOptimizedImage} from "@js/utils"
import landingImage from "@assets/images/landing.jpg" // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
const optimizedImage = await getOptimizedImage(landingImage)
---

<BaseLayout
  title="Boutique Shutters | Custom Window Treatments in Buford & Metro Atlanta"
  description="Elevate your home with premium shutters, shades & motorized window treatments in Suwanee, Johns Creek & Metro Atlanta. Free in-home design consultations."
  preloadedImage = {optimizedImage}
>

<!-- ============================================ -->
<!--                   Hero                       -->
<!-- ============================================ -->

<section id="hero-2349">
    <div class="cs-container">
        <div class="cs-content">
            <span class="cs-topper">Custom Window Treatments in Metro Atlanta</span>
            <h2 class="cs-title">Transform Your Home with Premium Window Shutters & Shades</h2>
            <p class="cs-text">
                At Boutique Shutters, we blend elegant design with superior functionality, creating custom window treatments that elevate your home's style and comfort. From premium plantation shutters to smart motorized shades, we provide expert consultation and flawless installation for homes throughout Sugar Hill, Suwanee, and the greater Atlanta area.
            </p>
            <a href="" class="cs-button-solid">Book A Call</a>
        </div>
    </div>
<ul class="cs-stats">
        <li class="cs-item">
            <span class="cs-number">
                <span class="cs-color">5</span>
